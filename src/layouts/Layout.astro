---
import favicon from "../assets/images/favicon-health-and-motion.webp";
import WhatsAppButton from "../components/WhatsAppButton.astro";

const {
  title,
  description = "Centro médico multidisciplinar especializado en entrenamiento personal, estética, fisioterapia, nutrición y psicología. Tu bienestar integral en un solo lugar."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/webp" href={favicon.src} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="font-body text-gray-800 antialiased">
    <slot />
    <WhatsAppButton />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
