---
import { ArrowRight, BadgeCheck, Check } from '@lucide/astro';

import Button from './ui/Button.astro';
import Badge from './ui/Badge.astro';
import LeadForm from './LeadForm.astro';
import type { Props as ButtonProps } from './ui/Button.astro';

interface HeroImage {
  src: string;
}

interface Props {
  badge?: string;
  badgeColor?: 'primary' | 'blue' | 'green' | 'red' | 'yellow';
  badgeTag?: 'div' | 'p' | 'h1';
  title: string;
  titleTag?: 'h1' | 'p';
  subtitle: string;
  subtitleHtml?: string;
  highlight?: string;
  accentColor?: 'primary' | 'accent';
  image?: HeroImage | string;
  imageAlt?: string;
  imageBadgeTitle?: string;
  imageBadgeSubtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  showPrimaryCta?: boolean;
  secondaryCta?: string;
  secondaryCtaHref?: string;
  secondaryCtaVariant?: ButtonProps['variant'];
  showSecondaryCta?: boolean;
  stats?: { value: string; label: string }[];
  features?: { text: string; checked?: boolean }[];
  variant?: 'primary' | 'blue';
}

const { 
  badge = "Centro Médico Multidisciplinar",
  badgeColor = 'primary',
  badgeTag = 'div',
  title,
  titleTag = 'h1',
  subtitle,
  subtitleHtml,
  highlight,
  accentColor,
  image,
  imageAlt = title,
  imageBadgeTitle = "Equipo Profesional",
  imageBadgeSubtitle = "Certificados",
  ctaText = "Pedir Cita Gratis",
  ctaHref = "#contacto",
  showPrimaryCta = true,
  secondaryCta = "Ver Servicios",
  secondaryCtaHref = "#servicios",
  secondaryCtaVariant = 'secondary',
  showSecondaryCta = true,
  stats = [
    { value: "5", label: "Especialidades" },
    { value: "+10", label: "Profesionales" },
    { value: "+1000", label: "Pacientes" }
  ],
  features = [
    { text: "Sin esperas", checked: true },
    { text: "Tratamiento personalizado", checked: true },
    { text: "Resultados garantizados", checked: true }
  ],
  variant = 'primary'
} = Astro.props;

const resolvedAccentColor = accentColor ?? (variant === 'blue' ? 'accent' : 'primary');

const gradient = resolvedAccentColor === 'accent'
  ? 'from-accent-50 via-white to-primary-50/40'
  : 'from-primary-50 via-white to-primary-50/40';

const highlightClass = resolvedAccentColor === 'accent' ? 'text-accent-600' : 'text-primary-600';
const bgPrimary = resolvedAccentColor === 'accent' ? 'bg-accent-100' : 'bg-primary-100';
const textPrimary = resolvedAccentColor === 'accent' ? 'text-accent-600' : 'text-primary-600';
const secondaryGlow = resolvedAccentColor === 'accent' ? 'bg-accent-200/20' : 'bg-primary-200/20';
const BadgeTag = badgeTag;
const TitleTag = titleTag;
const imageSrc = typeof image === 'string' ? image : image?.src;
---

<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
  <div class={`absolute inset-0 bg-gradient-to-br ${gradient}`}></div>
  <div class="absolute top-32 right-0 w-[500px] h-[500px] bg-primary-200/20 rounded-full blur-3xl"></div>
  <div class={`absolute bottom-0 left-0 w-[400px] h-[400px] ${secondaryGlow} rounded-full blur-3xl`}></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <BadgeTag>
          <Badge color={badgeColor} pulse>
            {badge}
          </Badge>
        </BadgeTag>
        
        <TitleTag class="text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-gray-900 leading-tight mt-6 mb-6">
          {highlight ? (
            <>
              {title.split(highlight)[0]}
              <span class={highlightClass}>{highlight}</span>
              {title.split(highlight)[1]}
            </>
          ) : title}
        </TitleTag>
        
        <p
          class="text-lg sm:text-xl text-gray-600 mb-8 max-w-xl mx-auto lg:mx-0"
          set:html={subtitleHtml ?? subtitle}
        />

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          {showPrimaryCta && (
            <Button href={ctaHref} variant="primary" size="lg" class="w-full max-w-full gap-2 text-center leading-tight sm:w-auto sm:min-w-[280px] sm:whitespace-nowrap">
              {ctaText}
              <ArrowRight class="h-5 w-5 shrink-0" aria-hidden="true" />
            </Button>
          )}
          {showSecondaryCta && (
            <Button href={secondaryCtaHref} variant={secondaryCtaVariant} size="lg">
              {secondaryCta}
            </Button>
          )}
        </div>

        {stats.length > 0 && (
          <div class="mt-10 flex items-center justify-center lg:justify-start space-x-8">
            {stats.map((stat, index) => (
              <>
                <div class="text-center">
                  <div class="text-3xl font-bold text-primary-600">{stat.value}</div>
                  <div class="text-sm text-gray-500">{stat.label}</div>
                </div>
                {index < stats.length - 1 && <div class="w-px h-12 bg-gray-300"></div>}
              </>
            ))}
          </div>
        )}

        {features.length > 0 && (
          <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-4">
            {features.map((feature) => (
              <div class="flex items-center text-gray-600">
                <Check class="mr-2 h-5 w-5 text-primary-500" aria-hidden="true" />
                <span class="text-sm font-medium">{feature.text}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="relative">
        {imageSrc ? (
          <div class="overflow-hidden rounded-[2rem] border border-white/60 bg-white shadow-2xl">
            <img
              src={imageSrc}
              alt={imageAlt}
              class="h-full w-full object-cover"
              loading="eager"
            />
          </div>
        ) : (
          <LeadForm variant={variant} />
        )}
        
        <div class="absolute -top-6 -right-6 bg-white rounded-2xl shadow-xl p-4 flex items-center space-x-3 animate-bounce" style="animation-duration: 3s;">
          <div class={`w-12 h-12 ${bgPrimary} rounded-full flex items-center justify-center`}>
            <BadgeCheck class={`h-6 w-6 ${textPrimary}`} aria-hidden="true" />
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900">{imageBadgeTitle}</div>
            <div class="text-xs text-gray-500">{imageBadgeSubtitle}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
