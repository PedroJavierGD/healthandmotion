---
import {
  Apple,
  Brain,
  Check,
  ChevronRight,
  Dumbbell,
  HeartPulse,
  Sparkles,
} from "@lucide/astro";

import Container from "./ui/Container.astro";
import Heading from "./ui/Heading.astro";
import Badge from "./ui/Badge.astro";
import Card from "./ui/Card.astro";
import Section from "./ui/Section.astro";
import imagenFisioterapiaHome from "../assets/images/home/fisioterapia-ecografia-clinica.webp";
import imagenEntrenamientoHome from "../assets/images/home/centro-entrenamiento-personal-sanlucar.webp";
import imagenNutricionHome from "../assets/images/home/servicio-nutricionista-sanlucar.webp";
import imagenEsteticaHome from "../assets/images/home/servicio-estetica-sanlucar.webp";

const imagenesServicios = import.meta.glob("../assets/images/*.webp", {
  eager: true,
  import: "default"
});

const normalizarTexto = (texto) =>
  texto.normalize("NFD").replace(/\p{Diacritic}/gu, "").toLowerCase();

const buscarImagenServicio = (terminos) => {
  const terminosNormalizados = terminos.map(normalizarTexto);

  return Object.entries(imagenesServicios).find(([ruta]) => {
    const rutaNormalizada = normalizarTexto(ruta);
    return terminosNormalizados.every((termino) => rutaNormalizada.includes(termino));
  })?.[1];
};

const obtenerSrcImagen = (imagen) => (typeof imagen === "string" ? imagen : imagen?.src ?? "");

const servicios = [
  {
    titulo: "Fisioterapia",
    descripcion:
      "Recuperación de lesiones y tratamiento del dolor con técnicas avanzadas.",
    icono: HeartPulse,
    imagen: imagenFisioterapiaHome,
    color: "from-primary-400 to-primary-600",
    items: ["Readaptación deportiva", "Tratamiento del dolor"],
    enlace: "/clinica-de-fisioterapia-en-sanlucar-de-barrameda",
  },
  {
    titulo: "Entrenamiento Personal",
    descripcion:
      "Planes personalizados adaptados a tus objetivos. Supervision profesional para maximizar resultados.",
    icono: Dumbbell,
    imagen: imagenEntrenamientoHome,
    color: "from-primary-500 to-primary-700",
    items: ["Planes adaptados a tu nivel", "Seguimiento personalizado"],
    enlace: "/entrenamiento-personal-en-sanlucar",
  },
  {
    titulo: "Nutricionista",
    descripcion:
      "Asesoría alimentaria personalizada para mejorar tu salud y hábitos.",
    icono: Apple,
    imagen: imagenNutricionHome,
    color: "from-primary-400 to-primary-600",
    items: ["Pérdida de peso", "Deportiva y digestiva"],
    enlace: "/nutricionista-en-sanlucar-de-barrameda",
  },
  {
    titulo: "Psicología",
    descripcion: "Acompañamiento profesional para tu salud mental y emocional.",
    icono: Brain,
    imagen: buscarImagenServicio(["psicologa"]),
    color: "from-accent-400 to-accent-600",
    items: ["Terapia individual", "Pareja y online"],
    enlace: "/psicologa-en-sanlucar-de-barrameda",
  },
  {
    titulo: "Estética",
    descripcion:
      "Tratamientos avanzados para cuidar tu imagen y potenciar tu confianza.",
    icono: Sparkles,
    imagen: imagenEsteticaHome,
    objectPosition: "center 75%",
    color: "from-accent-400 to-accent-600",
    items: ["Tratamientos faciales", "Corporal e higiene"],
    enlace: "/esteticista-en-sanlucar-de-barrameda",
  },
];
---

<Section id="servicios">
  <Container>
    <div class="text-center mb-16">
      <Badge color="primary">Nuestros Servicios</Badge>
      <Heading level={2} center class="mt-4">
        Cuidamos todas las áreas de tu salud
      </Heading>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
        Un enfoque integral para que logres tus objetivos de bienestar físico y
        mental.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-6">
      {
        servicios.map((servicio, index) => {
          const esPenultimoEnFilaDeDos =
            servicios.length % 3 === 2 && index === servicios.length - 2;
          const esUltimoEnFilaDeDos =
            servicios.length % 3 === 2 && index === servicios.length - 1;

          return (
          <Card
            hover
            class:list={[
              "lg:col-span-2",
              esPenultimoEnFilaDeDos && "lg:col-start-2",
              esUltimoEnFilaDeDos && "lg:col-start-4",
            ]}
          >
            {servicio.imagen ? (
              <div class="relative h-48 overflow-hidden">
                <img
                  src={obtenerSrcImagen(servicio.imagen)}
                  alt={servicio.titulo}
                  class="h-full w-full object-cover"
                  style={servicio.objectPosition ? `object-position: ${servicio.objectPosition};` : undefined}
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/10 to-transparent" />
              </div>
            ) : (
              <div
                class={`h-48 bg-gradient-to-br ${servicio.especial ? "from-primary-600 to-ink-900" : servicio.color} flex items-center justify-center`}
              >
                <servicio.icono
                  class="h-20 w-20 text-white/80"
                  stroke-width={1.5}
                  aria-hidden="true"
                />
              </div>
            )}
            <div class="p-6">
              <Heading level={3}>{servicio.titulo}</Heading>
              <p
                class={`mt-2 mb-4 ${servicio.especial ? "text-white/80" : "text-gray-500"}`}
              >
                {servicio.descripcion}
              </p>
              <ul class="space-y-2 mb-4">
                {servicio.items.map((item) => (
                  <li class="flex items-center text-sm text-gray-600">
                    <Check
                      class={`mr-2 h-4 w-4 ${servicio.especial ? "text-white" : "text-primary-500"}`}
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href={servicio.enlace}
                class={`font-semibold inline-flex items-center ${servicio.especial ? "text-white hover:text-white/80" : "text-primary-600 hover:text-primary-700"}`}
              >
                Más información
                <ChevronRight class="ml-1 h-4 w-4" aria-hidden="true" />
              </a>
            </div>
          </Card>
          );
        })
      }
    </div>
  </Container>
</Section>
