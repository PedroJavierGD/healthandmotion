---
import { BadgeCheck, ClipboardList, Clock3, Cpu, Users } from "@lucide/astro";

const ventajas = [
  {
    titulo: "Fisioterapeutas Profesionales",
    descripcion: "Fisioterapeutas colegiados con formación continua.",
    icono: BadgeCheck,
    posicion: "lg:col-span-2",
  },
  {
    titulo: "Tratamiento a Medida",
    descripcion:
      "Valoramos tu caso de forma individual para entender qué te pasa y qué tratamiento encaja mejor contigo.",
    icono: ClipboardList,
    posicion: "lg:col-span-2",
  },
  {
    titulo: "Cercanía y Seguimiento",
    descripcion:
      "Queremos que te sientas acompañado durante el proceso, con una atención cercana y un seguimiento orientado a tu recuperación.",
    icono: Users,
    posicion: "lg:col-span-2",
  },
  {
    titulo: "Sin listas de esperas",
    descripcion: "Cita en 24/48 horas.",
    icono: Clock3,
    posicion: "lg:col-span-2 lg:col-start-2",
  },
  {
    titulo: "Fisioterapia Avanzada",
    descripcion: "Equipamiento de última generación.",
    icono: Cpu,
    posicion: "lg:col-span-2",
  },
];
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-gray-900">
        ¿Por qué elegir nuestra clínica de fisioterapia en Sanlúcar?
      </h2>
      <p class="mt-4 max-w-3xl mx-auto text-lg text-gray-500">
        Sabemos que no hay dos personas iguales ni dos lesiones que deban
        tratarse de la misma manera. Por eso, como fisioterapeutas, trabajamos
        desde una atención personalizada, adaptando cada tratamiento a lo que
        realmente necesitas en cada momento.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-6">
      {
        ventajas.map((ventaja) => (
          <article
            class:list={[
              "rounded-3xl border border-primary-100 bg-white p-7 text-center shadow-[0_18px_45px_rgba(47,60,46,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_55px_rgba(47,60,46,0.1)]",
              ventaja.posicion,
            ]}
          >
            <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-100">
              <ventaja.icono
                class="h-8 w-8 text-primary-600"
                aria-hidden="true"
              />
            </div>
            <p class="mb-3 text-lg font-semibold text-gray-900">
              {ventaja.titulo}
            </p>
            <p class="text-sm leading-6 text-gray-500">{ventaja.descripcion}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
