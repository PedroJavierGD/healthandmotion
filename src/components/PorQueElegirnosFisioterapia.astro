---
import { Activity, ClipboardList, Clock3, ShieldCheck } from '@lucide/astro';
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-gray-900">
        ¿Por qué elegir nuestra clínica?
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center p-6">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <ShieldCheck class="h-8 w-8 text-primary-600" aria-hidden="true" />
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Profesionales Cualificados</h3>
        <p class="text-gray-500">Fisioterapeutas colegiados con formación continua</p>
      </div>

      <div class="text-center p-6">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <ClipboardList class="h-8 w-8 text-primary-600" aria-hidden="true" />
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Tratamiento Personalizado</h3>
        <p class="text-gray-500">Plan de recuperación adaptado a tu caso</p>
      </div>

      <div class="text-center p-6">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <Clock3 class="h-8 w-8 text-primary-600" aria-hidden="true" />
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Sin Listas de Espera</h3>
        <p class="text-gray-500">Primera cita en 24-48 horas</p>
      </div>

      <div class="text-center p-6">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <Activity class="h-8 w-8 text-primary-600" aria-hidden="true" />
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Instalaciones Modernas</h3>
        <p class="text-gray-500">Equipamiento de última generación</p>
      </div>
    </div>
  </div>
</section>
