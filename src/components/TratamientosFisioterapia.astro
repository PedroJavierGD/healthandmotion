---
import {
  Activity,
  Check,
  ChevronRight,
  Dumbbell,
  Hand,
  HeartPulse,
  Stethoscope,
  Zap,
} from "@lucide/astro";

const tratamientos = [
  {
    titulo: "Readaptación Deportiva",
    descripcion:
      "Recuperación de lesiones deportivas con programas personalizados para volver a tu actividad.",
    icono: Dumbbell,
    color: "from-primary-500 to-primary-700",
    items: ["Esguinces y desgarros", "Tendinitis"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia Traumatológica",
    descripcion:
      "Tratamiento de lesiones traumatológicas y procesos post-quirúrgicos.",
    icono: Stethoscope,
    color: "from-accent-400 to-accent-600",
    items: ["Post-operatorios", "Fracturas"],
    enlace: "#contacto",
  },
  {
    titulo: "Tratamiento del Dolor",
    descripcion: "Técnicas avanzadas para eliminar o reducir el dolor crónico.",
    icono: HeartPulse,
    color: "from-ink-600 to-ink-800",
    items: ["Dolor de espalda", "Cervicalgias y lumbalgias"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia Respiratoria",
    descripcion:
      "Tratamientos para enfermedades respiratorias y mejora de la capacidad pulmonar.",
    icono: Activity,
    color: "from-primary-400 to-primary-600",
    items: ["Asma", "EPOC"],
    enlace: "#contacto",
  },
  {
    titulo: "Terapia Manual",
    descripcion: "Técnicas de masaje y movilización para restaurar la función.",
    icono: Hand,
    color: "from-accent-300 to-accent-500",
    items: ["Masaje terapéutico", "Osteopatía"],
    enlace: "#contacto",
  },
  {
    titulo: "Electroterapia",
    descripcion:
      "Tratamientos con tecnología avanzada para acelerar la recuperación.",
    icono: Zap,
    color: "from-ink-500 to-ink-700",
    items: ["Ultrasonidos", "Laserterapia"],
    enlace: "#contacto",
  },
];
---

<section id="tratamientos" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span
        class="text-primary-600 font-semibold tracking-wide uppercase text-sm"
        >Fisioterapia para distintos tipos de molestias y lesiones</span
      >
      <h2
        class="mt-2 text-3xl sm:text-4xl font-heading font-bold text-gray-900"
      >
        Servicios de fisioterapia
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
        Tratamientos especializados para cada necesidad. Tecnologías avanzadas y
        técnicas manuales.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        tratamientos.map((tratamiento) => (
          <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 overflow-hidden hover:-translate-y-1">
            <div
              class={`h-48 bg-gradient-to-br ${tratamiento.color} flex items-center justify-center`}
            >
              <tratamiento.icono
                class="h-20 w-20 text-white/80"
                stroke-width={1.5}
                aria-hidden="true"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-heading font-bold text-gray-900 mb-2">
                {tratamiento.titulo}
              </h3>
              <p class="text-gray-500 mb-4">{tratamiento.descripcion}</p>
              <ul class="space-y-2 mb-4">
                {tratamiento.items.map((item) => (
                  <li class="flex items-center text-sm text-gray-600">
                    <Check
                      class="mr-2 h-4 w-4 text-primary-500"
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href={tratamiento.enlace}
                class="text-primary-600 font-semibold hover:text-primary-700 inline-flex items-center"
              >
                Más información
                <ChevronRight class="ml-1 h-4 w-4" aria-hidden="true" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
