---
import {
  Activity,
  Check,
  ChevronRight,
  Dumbbell,
  Hand,
  HeartPulse,
  Stethoscope,
  Zap,
} from "@lucide/astro";

const tratamientos = [
  {
    titulo: "Fisioterapia para suelo pélvico",
    descripcion:
      "Tratamiento especializado para mejorar la función del suelo pélvico y ayudarte a recuperar bienestar, control y calidad de vida.",
    icono: Stethoscope,
    color: "from-ink-500 to-ink-700",
    items: ["Valoración individual", "Reeducación funcional"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia respiratoria",
    descripcion:
      "Tratamiento enfocado en mejorar la función respiratoria, aliviar síntomas y ayudarte a respirar con mayor comodidad y eficacia.",
    icono: Activity,
    color: "from-accent-300 to-accent-500",
    items: [
      "Mejora de la capacidad pulmonar",
      "Tratamiento adaptado a cada caso",
    ],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia a domicilio",
    descripcion:
      "Sesiones de fisioterapia en casa para que recibas atención profesional, cómoda y personalizada sin necesidad de desplazarte.",
    icono: Hand,
    color: "from-primary-500 to-primary-700",
    items: ["Atención cómoda", "Tratamiento personalizado"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia deportiva",
    descripcion:
      "Tratamiento orientado a prevenir, recuperar y optimizar lesiones deportivas para que puedas volver a entrenar con seguridad.",
    icono: Dumbbell,
    color: "from-ink-600 to-ink-800",
    items: ["Prevención de recaídas", "Mejora del rendimiento"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia infantil",
    descripcion:
      "Abordaje especializado para bebés, niños y adolescentes con un tratamiento adaptado a cada etapa de desarrollo y necesidad.",
    icono: HeartPulse,
    color: "from-primary-400 to-primary-600",
    items: ["Atención adaptada", "Seguimiento cercano"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia neurológica",
    descripcion:
      "Tratamiento dirigido a mejorar la movilidad, el control motor y la autonomía en personas con alteraciones neurológicas.",
    icono: Activity,
    color: "from-accent-400 to-accent-600",
    items: ["Reeducación del movimiento", "Mayor funcionalidad"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia para embarazadas",
    descripcion:
      "Acompañamiento fisioterapéutico durante el embarazo para aliviar molestias, mejorar el bienestar y preparar el cuerpo para el parto.",
    icono: HeartPulse,
    color: "from-primary-500 to-primary-700",
    items: ["Alivio de molestias", "Preparación al parto"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia con ecografía",
    descripcion:
      "Valoración y seguimiento del tratamiento mediante ecografía para trabajar con mayor precisión y adaptar mejor cada intervención.",
    icono: Zap,
    color: "from-ink-600 to-ink-800",
    items: ["Diagnóstico más preciso", "Tratamiento guiado"],
    enlace: "#contacto",
  },
  {
    titulo: "Fisioterapia con Indiba",
    descripcion:
      "Tecnología avanzada aplicada a fisioterapia para acelerar la recuperación, reducir el dolor y favorecer la regeneración tisular.",
    icono: Zap,
    color: "from-accent-400 to-accent-600",
    items: ["Recuperación más rápida", "Reducción del dolor"],
    enlace: "#contacto",
  },
];
---

<section id="tratamientos" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="text-primary-600 font-semibold tracking-wide uppercase text-sm"
      >
        Tratamientos de fisioterapia para distintos tipos de molestias y
        lesiones
      </h2>
      <p class="mt-2 text-3xl sm:text-4xl font-heading font-bold text-gray-900">
        Tratamos problemas frecuentes y específicos los cuales afectan mucho en
        tu día a día
      </p>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
        Si sientes dolor, rigidez o molestias al moverte, <strong
          >no lo normalices</strong
        >. En nuestra clínica de fisioterapia en Sanlúcar tratamos diferentes
        problemas musculares y articulares para ayudarte a recuperar bienestar,
        movilidad y calidad de vida.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        tratamientos.map((tratamiento) => (
          <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 overflow-hidden hover:-translate-y-1">
            <div
              class={`h-48 bg-gradient-to-br ${tratamiento.color} flex items-center justify-center`}
            >
              <tratamiento.icono
                class="h-20 w-20 text-white/80"
                stroke-width={1.5}
                aria-hidden="true"
              />
            </div>
            <div class="p-6">
              <p class="text-xl font-heading font-bold text-gray-900 mb-2">
                {tratamiento.titulo}
              </p>
              <p class="text-gray-500 mb-4">{tratamiento.descripcion}</p>
              <ul class="space-y-2 mb-4">
                {tratamiento.items.map((item) => (
                  <li class="flex items-center text-sm text-gray-600">
                    <Check
                      class="mr-2 h-4 w-4 text-primary-500"
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href={tratamiento.enlace}
                class="text-primary-600 font-semibold hover:text-primary-700 inline-flex items-center"
              >
                Solicitar cita
                <ChevronRight class="ml-1 h-4 w-4" aria-hidden="true" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
