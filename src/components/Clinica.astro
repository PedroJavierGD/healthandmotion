---
import foto1 from "../assets/images/home/foto-home-1-health-motion.webp";
import foto2 from "../assets/images/home/foto-home-2-health-motion.webp";
import foto3 from "../assets/images/home/foto-home-3-health-motion.webp";
import foto4 from "../assets/images/home/foto-home-4-health-motion.webp";
import foto5 from "../assets/images/home/foto-home-5-health-motion.webp";
import foto6 from "../assets/images/home/foto-home-6-health-motion.webp";
import foto7 from "../assets/images/home/foto-home-7-health-motion.webp";
import foto8 from "../assets/images/home/foto-home-8-health-motion.webp";
import foto9 from "../assets/images/home/foto-home-9-health-motion.webp";
import fotoEntrenamiento from "../assets/images/home/centro-entrenamiento-personal-sanlucar.webp";

const imagenes = [
  {
    src: foto1.src,
    alt: "Recepción de Health and Motion",
    clase: "md:col-span-2 md:row-span-2",
  },
  {
    src: foto2.src,
    alt: "Instalaciones interiores de Health and Motion",
    clase: "",
  },
  {
    src: foto3.src,
    alt: "Zona clínica de Health and Motion",
    clase: "",
  },
  {
    src: foto4.src,
    alt: "Espacio de atención en Health and Motion",
    clase: "md:col-span-2",
  },
  {
    src: foto5.src,
    alt: "Detalle de las instalaciones de Health and Motion",
    clase: "",
  },
  {
    src: foto6.src,
    alt: "Consulta de Health and Motion",
    clase: "",
  },
  {
    src: foto7.src,
    alt: "Sala de tratamiento de Health and Motion",
    clase: "md:col-span-2",
  },
  {
    src: foto8.src,
    alt: "Cabina y equipamiento de Health and Motion",
    clase: "",
  },
  {
    src: foto9.src,
    alt: "Ambiente interior de Health and Motion",
    clase: "",
  },
  {
    src: fotoEntrenamiento.src,
    alt: "Zona de entrenamiento personal en Health and Motion",
    clase: "md:col-span-2",
  },
];
---

<section id="clinica" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span
        class="inline-block px-4 py-1.5 bg-primary-100 text-primary-700 font-semibold tracking-wide uppercase text-sm rounded-full"
        >Nuestra Clínica</span
      >
      <h2
        class="mt-6 text-4xl sm:text-5xl font-heading font-bold text-gray-900"
      >
        Un espacio diseñado para
        <span class="text-primary-600">tu bienestar</span>
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600">
        Descubre nuestras instalaciones modernas y acogedoras, donde cada
        detalle está pensado para que te sientas cómodo desde el primer momento.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 auto-rows-[220px] md:grid-cols-4 md:auto-rows-[220px] lg:auto-rows-[240px]">
      {
        imagenes.map((img, index) => (
          <div
            class={`group relative overflow-hidden rounded-2xl ${img.clase}`}
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading={index < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-white font-medium">{img.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-6">
      <div
        class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8 text-center"
      >
        <div
          class="w-16 h-16 bg-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-4"
        >
          <svg
            class="w-8 h-8 text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">600m²</h3>
        <p class="text-gray-600">De instalaciones modernas</p>
      </div>

      <div
        class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8 text-center"
      >
        <div
          class="w-16 h-16 bg-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-4"
        >
          <svg
            class="w-8 h-8 text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">13</h3>
        <p class="text-gray-600">Profesionales especializados</p>
      </div>

      <div
        class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8 text-center"
      >
        <div
          class="w-16 h-16 bg-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-4"
        >
          <svg
            class="w-8 h-8 text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">+1000</h3>
        <p class="text-gray-600">Pacientes satisfechos</p>
      </div>
    </div>
  </div>
</section>
