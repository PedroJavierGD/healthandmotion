---
import Hero from "../Hero.astro";
import imagenFisioterapia from "../../assets/images/fisioterapia/tratamiento-fisioterapia-clinica-sanlucar-health-motion.webp";
---

<Hero
  variant="blue"
  breadcrumbs={[
    { label: "Inicio", href: "/" },
    { label: "Fisioterapia" },
  ]}
  badge="Clínica de fisioterapia en Sanlúcar de Barrameda"
  badgeTag="h1"
  badgeColor="green"
  accentColor="primary"
  title="Recupera tu movilidad y di adiós al dolor"
  titleTag="p"
  highlight="di adiós al dolor"
  subtitle="En nuestra clínica de fisioterapia en Sanlúcar de Barrameda tratamos lesiones, sobrecargas, contracturas y molestias musculares con un enfoque personalizado para que vuelvas a encontrarte bien cuanto antes."
  subtitleHtml="En nuestra <strong>clínica de fisioterapia en Sanlúcar de Barrameda</strong> tratamos lesiones, sobrecargas, contracturas y molestias musculares con un enfoque personalizado para que vuelvas a encontrarte bien cuanto antes."
  image={imagenFisioterapia}
  imageAlt="Tratamiento de fisioterapia en Health and Motion"
  imageBadgeTitle="Fisioterapeutas Profesionales"
  imageBadgeSubtitle="Certificados"
  ctaText="Pedir Cita por WhatsApp"
  ctaHref="https://wa.me/34722664982?text=%C2%A1Hola%20Health%26Motion%21%20Vengo%20de%20la%20parte%20de%20fisioterapia%20de%20vuestra%20web%20y%20me%20gustar%C3%ADa%20pedir%20una%20cita%20%3A%29"
  showSecondaryCta={false}
  stats={[]}
  features={[
    { text: "Fisioterapia Avanzada", checked: true },
    { text: "Cita por WhatsApp", checked: true },
    { text: "Atención cercana y profesional", checked: true },
  ]}
/>
