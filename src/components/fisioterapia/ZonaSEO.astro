---
const fotosLocales = import.meta.glob("../../assets/images/*.webp", {
  eager: true,
  import: "default",
});

const normalizarTexto = (texto) =>
  texto
    .normalize("NFD")
    .replace(/\p{Diacritic}/gu, "")
    .replace(/[^a-zA-Z0-9]/g, "")
    .toLowerCase();

const buscarFotoEquipo = (terminos) => {
  const terminosNormalizados = terminos.map(normalizarTexto);

  return Object.entries(fotosLocales).find(([ruta]) => {
    const rutaNormalizada = normalizarTexto(ruta);
    return terminosNormalizados.every((termino) =>
      rutaNormalizada.includes(termino),
    );
  })?.[1];
};

const obtenerSrcFoto = (foto) =>
  typeof foto === "string" ? foto : (foto?.src ?? "");

const fisioterapeutas = [
  {
    nombre: "Lorena",
    puesto: "Fisioterapeuta",
    foto: buscarFotoEquipo(["lorena", "fisioterapeuta"]),
  },
  {
    nombre: "Leire",
    puesto: "Fisioterapeuta",
    foto: buscarFotoEquipo(["leire", "fisioterapeuta"]),
  },
  {
    nombre: "Jose",
    puesto: "Fisioterapeuta",
    foto: "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&h=500&fit=crop&crop=face",
  },
];
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-gray-900">
        Nuestro equipo de fisioterapia comprometido con tu bienestar
      </h2>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Detrás de cada tratamiento hay fisioterapeutas profesionales que te
        escuchan, valoran tu caso y trabajan contigo para ayudarte a mejorar. En
        nuestra clínica apostamos por una atención cercana, profesional y
        centrada en lo que realmente necesitas.
      </p>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto"
    >
      {
        fisioterapeutas.map((persona) => (
          <div class="group text-center">
            <div class="relative overflow-hidden rounded-xl aspect-[4/5] bg-gray-50">
              <img
                src={obtenerSrcFoto(persona.foto)}
                alt={persona.nombre}
                class="w-full h-full object-contain object-center transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <p class="mt-3 text-base font-semibold text-gray-900">
              {persona.nombre}
            </p>
            <p class="mt-2 text-sm font-medium text-primary-700">
              {persona.puesto}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
