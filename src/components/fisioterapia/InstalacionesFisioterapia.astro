---
import imagenSalaEspera from "../../assets/images/fisioterapia/sala-espera-clinica-fisioterapia-sanlucar.webp";
import imagenClinica from "../../assets/images/fisioterapia/clinica-fisioterapia-sanlucar-health-motion.webp";
import imagenRehabilitacion from "../../assets/images/fisioterapia/clinica-fisioterapia-rehabilitacion-personas-mayores-sanlucar.webp";
import imagenTratamiento from "../../assets/images/fisioterapia/tratamiento-fisioterapia-clinica-sanlucar-health-motion.webp";

const imagenes = [
  {
    src: imagenRehabilitacion.src,
    alt: "Clínica de fisioterapia y rehabilitación para personas mayores en Sanlúcar de Barrameda",
    clase: "md:col-span-2 md:row-span-2",
  },
  {
    src: imagenTratamiento.src,
    alt: "Tratamiento de fisioterapia en la clínica de Health and Motion",
    clase: "",
  },
  {
    src: imagenSalaEspera.src,
    alt: "Sala de espera de la clínica de fisioterapia de Health and Motion",
    clase: "",
  },
  {
    src: imagenClinica.src,
    alt: "Clínica de fisioterapia de Health and Motion en Sanlúcar de Barrameda",
    clase: "md:col-span-2",
  },
];

const espacios = [
  {
    titulo: "Boxes de tratamiento",
    descripcion:
      "Espacios cómodos y preparados para terapia manual, valoración y seguimiento.",
    valor: "3",
  },
  {
    titulo: "Zona de readaptación",
    descripcion:
      "Área pensada para ejercicio terapéutico y recuperación funcional progresiva.",
    valor: "1",
  },
  {
    titulo: "Ambiente cuidado",
    descripcion:
      "Un entorno limpio, moderno y tranquilo para que cada sesión sea más cómoda.",
    valor: "100%",
  },
];
---

<section id="instalaciones" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="inline-block px-4 py-1.5 bg-primary-100 text-primary-700 font-semibold tracking-wide uppercase text-sm rounded-full"
      >
        Nuestra clínica de fisioterapia en Sanlúcar de Barrameda
      </h2>
      <p class="mt-6 text-4xl sm:text-5xl font-heading font-bold text-gray-900">
        Una clínica pensada para
        <span class="text-primary-600"> tu recuperación</span>
      </p>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600">
        Espacios modernos, acogedores y preparados para que tu tratamiento de
        fisioterapia sea cómodo, preciso y efectivo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[250px]">
      {
        imagenes.map((img, index) => (
          <div
            class={`group relative overflow-hidden rounded-2xl ${img.clase}`}
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading={index < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-white font-medium">{img.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-6">
      {
        espacios.map((espacio) => (
          <div class="rounded-2xl bg-white p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-4xl font-heading font-extrabold text-primary-600">
              {espacio.valor}
            </div>
            <p class="mt-4 text-xl font-bold text-gray-900">
              {espacio.titulo}
            </p>
            <p class="mt-2 text-gray-600">{espacio.descripcion}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
