  badgeTag="h1"
  badgeColor="blue"
  title="Recupera tu movilidad y di adiós al dolor"
  titleTag="p"
  highlight="di adiós al dolor"
  subtitle="Tratamientos personalizados de fisioterapia para lesiones deportivas, dolor crónico, post-operatorios y más. Profesionales titulados con más de 10 años de experiencia."
  ctaText="Pedir Cita"
  secondaryCta="Ver Tratamientos"
  secondaryCtaHref="#tratamientos"
  stats={[]}
  features={[
    { text: "Sin esperas", checked: true },
    { text: "Tratamiento personalizado", checked: true },
    { text: "Resultados garantizados", checked: true },
  ]}
/>
