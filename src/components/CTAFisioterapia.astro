---
import { Mail, Phone } from '@lucide/astro';
---

<section id="contacto" class="py-20 bg-gradient-to-r from-blue-600 to-blue-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-4">
      ¿Necesitas un fisioterapeuta?
    </h2>
    <p class="text-xl text-white/80 mb-8">
      Reserva tu primera consulta gratuita. Te valoramos y te proponemos un tratamiento personalizado.
    </p>

    <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-lg mx-auto">
      <form class="space-y-4">
        <div>
          <input 
            type="text" 
            placeholder="Tu nombre" 
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition"
            required
          />
        </div>
        <div>
          <input 
            type="tel" 
            placeholder="Tu teléfono" 
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition"
            required
          />
        </div>
        <div>
          <select class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition">
            <option value="">¿Qué tipo de problema tienes?</option>
            <option value="lesion">Lesión deportiva</option>
            <option value="dolor-cronico">Dolor crónico</option>
            <option value="post-operatorio">Post-operatorio</option>
            <option value="columna">Problemas de columna</option>
            <option value="articulaciones">Problemas articulares</option>
            <option value="otro">Otro / No sé</option>
          </select>
        </div>
        <button 
          type="submit" 
          class="w-full py-4 bg-accent-500 hover:bg-accent-600 text-white font-bold rounded-lg transition shadow-md hover:shadow-lg text-lg"
        >
          Solicitar Cita Gratis
        </button>
        <p class="text-xs text-gray-400 text-center">
          Te llamaremos en menos de 24h para confirmar tu cita.
        </p>
      </form>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-8 text-white">
      <div class="flex items-center">
        <Phone class="mr-2 h-5 w-5" aria-hidden="true" />
        <span>+34 722 66 49 82</span>
      </div>
      <div class="flex items-center">
        <Mail class="mr-2 h-5 w-5" aria-hidden="true" />
        <span>fisioterapia@healthandmotion.es</span>
      </div>
    </div>
  </div>
</section>
