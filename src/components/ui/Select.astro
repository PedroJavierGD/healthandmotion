---
interface Option {
  value: string;
  label: string;
}

interface Props {
  name?: string;
  placeholder?: string;
  options: Option[];
  required?: boolean;
  class?: string;
  [key: string]: any;
}

const { 
  name,
  placeholder,
  options,
  required = false,
  class: className = '',
  ...rest 
} = Astro.props;
---

<select 
  name={name}
  required={required}
  class:list={[
    'w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition',
    className
  ]}
  {...rest}
>
  {placeholder && <option value="">{placeholder}</option>}
  {options.map((option) => (
    <option value={option.value}>{option.label}</option>
  ))}
</select>
