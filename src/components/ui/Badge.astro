---
interface Props {
  color?: 'primary' | 'blue' | 'green' | 'red' | 'yellow';
  pulse?: boolean;
  class?: string;
}

const { color = 'primary', pulse = false, class: className = '' } = Astro.props;

const colors = {
  primary: 'bg-primary-100 text-primary-700',
  blue: 'bg-blue-100 text-blue-700',
  green: 'bg-green-100 text-green-700',
  red: 'bg-red-100 text-red-700',
  yellow: 'bg-yellow-100 text-yellow-700'
};
---

<span class:list={[
  'inline-flex items-center px-4 py-2 rounded-full text-sm font-medium',
  colors[color],
  className
]}>
  {pulse && <span class="w-2 h-2 bg-current rounded-full mr-2 animate-pulse"></span>}
  <slot />
</span>
