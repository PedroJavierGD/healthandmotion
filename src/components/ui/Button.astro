---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: any;
}

const { 
  variant = 'primary', 
  size = 'md', 
  href, 
  type = 'button',
  class: className = '',
  ...rest 
} = Astro.props;

const variants = {
  primary: 'bg-primary-600 hover:bg-primary-700 text-white shadow-lg hover:shadow-xl',
  secondary: 'bg-white border-2 border-gray-200 hover:border-primary-300 text-ink-700',
  accent: 'bg-accent-500 hover:bg-accent-600 text-white',
  outline: 'border-2 border-primary-600 text-primary-600 hover:bg-primary-50'
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg'
};

const styles = `${variants[variant]} ${sizes[size]} inline-flex items-center justify-center font-semibold rounded-xl transition hover:-translate-y-0.5`;
---

{href ? (
  <a href={href} class:list={[styles, className]} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class:list={[styles, className]} {...rest}>
    <slot />
  </button>
)}
