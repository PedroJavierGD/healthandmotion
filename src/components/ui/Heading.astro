---
interface Props {
  level?: 1 | 2 | 3 | 4;
  class?: string;
  center?: boolean;
}

const { level = 1, class: className = '', center = false } = Astro.props;

const sizes = {
  1: 'text-4xl sm:text-5xl lg:text-6xl',
  2: 'text-3xl sm:text-4xl',
  3: 'text-2xl',
  4: 'text-xl'
};

const tags = { 1: 'h1', 2: 'h2', 3: 'h3', 4: 'h4' };
const Tag = tags[level];
---

<Tag class:list={[
  'font-heading font-bold text-gray-900',
  sizes[level],
  center && 'text-center',
  className
]}>
  <slot />
</Tag>
