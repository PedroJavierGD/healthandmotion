---
interface Props {
  id?: string;
  class?: string;
  background?: 'white' | 'gray' | 'primary' | 'blue' | 'accent';
}

const { id, class: className = '', background = 'white' } = Astro.props;

const backgrounds = {
  white: 'bg-white',
  gray: 'bg-gray-50',
  primary: 'bg-primary-600',
  blue: 'bg-primary-50',
  accent: 'bg-accent-50'
};
---

<section 
  id={id}
  class:list={[
    'py-20',
    backgrounds[background],
    className
  ]}
>
  <slot />
</section>
