</section>

<script is:inline define:vars={{ clonesPorLado, totalTestimonios: testimonios.length }}>
  (() => {
    const section = document.querySelector("#testimonios-fisioterapia");
    if (!section) return;

    const track = section.querySelector("[data-carousel-track]");
    const viewport = section.querySelector("[data-carousel-viewport]");
    const prevButtons = section.querySelectorAll("[data-carousel-prev]");
    const nextButtons = section.querySelectorAll("[data-carousel-next]");

    if (!track || !viewport || !prevButtons.length || !nextButtons.length) return;

    const transitionMs = 500;
    const autoplayMs = 2000;
    let currentIndex = clonesPorLado;
    let autoplayId;
    let resumeTimeoutId;
    let isTransitioning = false;
    const reviewTexts = Array.from(section.querySelectorAll("[data-review-text]"));
    const reviewToggles = Array.from(section.querySelectorAll("[data-review-toggle]"));

    const getSlidesPerView = () => {
      if (window.innerWidth >= 1280) return 3;
      if (window.innerWidth >= 768) return 2;
      return 1;
    };

    const getGap = () => {
      const styles = window.getComputedStyle(track);
      return Number.parseFloat(styles.columnGap || styles.gap || "0");
    };

    const updatePosition = (withTransition = true) => {
      const firstSlide = track.children[0];
      if (!firstSlide) return;

      const slideWidth = firstSlide.getBoundingClientRect().width;
      const step = slideWidth + getGap();
      track.style.transition = withTransition ? `transform ${transitionMs}ms ease` : "none";
      track.style.transform = `translate3d(-${currentIndex * step}px, 0, 0)`;
    };

    const syncInfiniteLoop = () => {
      if (currentIndex >= totalTestimonios + clonesPorLado) {
        currentIndex = clonesPorLado;
        updatePosition(false);
      } else if (currentIndex < clonesPorLado) {
        currentIndex = totalTestimonios + currentIndex;
        updatePosition(false);
      }
    };

    const moveTo = (direction) => {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex += direction;
      updatePosition(true);
    };

    const stopAutoplay = () => {
      window.clearInterval(autoplayId);
      window.clearTimeout(resumeTimeoutId);
    };

    const startAutoplay = () => {
      stopAutoplay();
      autoplayId = window.setInterval(() => moveTo(1), autoplayMs);
    };

    const pauseAndResumeAutoplay = () => {
      stopAutoplay();
      resumeTimeoutId = window.setTimeout(() => startAutoplay(), autoplayMs * 2);
    };

    const syncReviewButtons = () => {
      reviewTexts.forEach((text, index) => {
        const button = reviewToggles[index];
        if (!button) return;

        const isExpanded = text.classList.contains("is-expanded");
        if (isExpanded) {
          button.classList.remove("hidden");
          button.textContent = "Leer menos";
          return;
        }

        const hasOverflow = text.scrollHeight > text.clientHeight + 1;
        button.classList.toggle("hidden", !hasOverflow);
        button.textContent = "Leer más";
        button.setAttribute("aria-expanded", "false");
      });
    };

    prevButtons.forEach((button) => {
      button.addEventListener("click", () => {
        moveTo(-1);
        pauseAndResumeAutoplay();
      });
    });

    nextButtons.forEach((button) => {
      button.addEventListener("click", () => {
        moveTo(1);
        pauseAndResumeAutoplay();
      });
    });

    reviewToggles.forEach((button, index) => {
      button.addEventListener("click", () => {
        const text = reviewTexts[index];
        if (!text) return;

        const willExpand = !text.classList.contains("is-expanded");
        text.classList.toggle("is-expanded", willExpand);
        button.textContent = willExpand ? "Leer menos" : "Leer más";
        button.setAttribute("aria-expanded", String(willExpand));
      });
    });

    track.addEventListener("transitionend", () => {
      isTransitioning = false;
      syncInfiniteLoop();
    });

    viewport.addEventListener("mouseenter", stopAutoplay);
    viewport.addEventListener("mouseleave", startAutoplay);
    viewport.addEventListener("focusin", stopAutoplay);
    viewport.addEventListener("focusout", startAutoplay);

    window.addEventListener("resize", () => {
      section.style.setProperty("--slides-per-view", String(getSlidesPerView()));
      updatePosition(false);
      syncReviewButtons();
    });

    section.style.setProperty("--slides-per-view", String(getSlidesPerView()));
    updatePosition(false);
    syncReviewButtons();
    startAutoplay();
  })();
</script>

<style>
  #testimonios-fisioterapia {
    --carousel-gap: 1.5rem;
    --slides-per-view: 1;
  }

  #testimonios-fisioterapia .carousel-track {
    gap: var(--carousel-gap);
    will-change: transform;
  }

  #testimonios-fisioterapia .carousel-slide {
    width: calc(
      (100% - (var(--carousel-gap) * (var(--slides-per-view) - 1))) /
        var(--slides-per-view)
    );
  }

  #testimonios-fisioterapia .carousel-button {
    height: 3rem;
    width: 3rem;
  }

  #testimonios-fisioterapia .review-text {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 7;
  }

  #testimonios-fisioterapia .review-text.is-expanded {
    display: block;
    overflow: visible;
  }

  @media (min-width: 768px) {
    #testimonios-fisioterapia {
      --slides-per-view: 2;
    }
  }

  @media (min-width: 1280px) {
    #testimonios-fisioterapia {
      --slides-per-view: 3;
    }
  }
</style>
