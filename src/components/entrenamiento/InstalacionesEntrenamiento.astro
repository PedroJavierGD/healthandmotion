---
import imagenEntrenamiento from "../../assets/images/entrenamiento personal en sanlucar de barrameda.webp";
import imagenFabi from "../../assets/images/Fabi - Entrenador personal en Health&Motion.webp";
import imagenManu from "../../assets/images/Manu - Entrenador personal en Health&Motion.webp";
import imagenAndrea from "../../assets/images/Andrea - Entrenadora personal en Health&Motion.webp";

const imagenes = [
  {
    src: imagenEntrenamiento.src,
    alt: "Entrenamiento personal guiado en Health and Motion",
    clase: "md:col-span-2 md:row-span-2",
  },
  {
    src: imagenFabi.src,
    alt: "Entrenadora personal de Health and Motion",
    clase: "",
  },
  {
    src: imagenManu.src,
    alt: "Entrenador personal de Health and Motion",
    clase: "",
  },
  {
    src: imagenAndrea.src,
    alt: "Entrenamiento adaptado en clínica",
    clase: "md:col-span-2",
  },
];

const espacios = [
  {
    titulo: "Programas específicos",
    descripcion:
      "Grupos diseñados para embarazo, post parto, espalda y rehabilitación.",
    valor: "4",
  },
  {
    titulo: "Trabajo semanal",
    descripcion:
      "Sesiones organizadas para crear continuidad y mejorar progresivamente.",
    valor: "2",
  },
  {
    titulo: "Acompañamiento",
    descripcion:
      "Orientación profesional para que entrenes con seguridad y confianza.",
    valor: "100%",
  },
];
---

<section id="instalaciones" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="inline-block px-4 py-1.5 bg-primary-100 text-primary-700 font-semibold tracking-wide uppercase text-sm rounded-full"
      >
        Nuestra zona de entrenamiento en Sanlúcar de Barrameda
      </h2>
      <p class="mt-6 text-4xl sm:text-5xl font-heading font-bold text-gray-900">
        Un espacio pensado para
        <span class="text-primary-600"> moverte mejor</span>
      </p>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600">
        Entrenamiento en clínica, con profesionales cerca y una metodología
        adaptada para que progreses sin improvisar.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[250px]">
      {
        imagenes.map((img, index) => (
          <div
            class={`group relative overflow-hidden rounded-2xl bg-white ${img.clase}`}
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-110"
              loading={index < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-white font-medium">{img.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-6">
      {
        espacios.map((espacio) => (
          <article class="rounded-2xl bg-white p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-4xl font-heading font-extrabold text-primary-600">
              {espacio.valor}
            </div>
            <p class="mt-4 text-xl font-bold text-gray-900">
              {espacio.titulo}
            </p>
            <p class="mt-2 text-gray-600">{espacio.descripcion}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
