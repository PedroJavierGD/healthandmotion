---
import { BadgeCheck } from "@lucide/astro";

import entrenamientoImage from "../../assets/images/entrenamiento-personal-sanlucar-barrameda.webp";

import FormularioEntrenamiento from "./FormularioEntrenamiento.astro";
---

<div class="relative">
  <div
    class="overflow-hidden rounded-[2rem] border border-white/80 bg-white shadow-2xl shadow-primary-100/60"
  >
    <div class="relative h-72">
      <img
        src={entrenamientoImage.src}
        alt="Entrenamiento personal en Health and Motion"
        class="h-full w-full object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-ink-900/60 via-transparent to-transparent"
      >
      </div>
      <div
        class="absolute left-6 bottom-6 rounded-2xl bg-white/92 px-5 py-4 shadow-lg backdrop-blur"
      >
        <div class="text-sm font-semibold text-primary-700">Health & Motion</div>
        <div class="mt-1 text-2xl font-bold text-gray-900">
          Entrena con objetivo clínico
        </div>
      </div>
    </div>

    <FormularioEntrenamiento />
  </div>

  <div
    class="absolute -left-6 top-12 hidden rounded-2xl bg-accent-500 px-5 py-4 text-white shadow-xl lg:block"
  >
    <div class="flex items-center gap-3">
      <BadgeCheck class="h-6 w-6" aria-hidden="true" />
      <div>
        <div class="text-sm font-semibold">Orientación personalizada</div>
        <div class="text-xs text-white/80">Te ayudamos a elegir grupo</div>
      </div>
    </div>
  </div>
</div>
