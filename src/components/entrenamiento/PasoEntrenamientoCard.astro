---
import type { PasoEntrenamiento } from "../../data/entrenamientoPersonal";

interface Props {
  paso: PasoEntrenamiento;
  index: number;
}

const { paso, index } = Astro.props;
---

<div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
  <div class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-200">
    Paso {index + 1}
  </div>
  <h3 class="mt-4 text-2xl font-bold">{paso.titulo}</h3>
  <p class="mt-3 text-white/75">{paso.texto}</p>
</div>
