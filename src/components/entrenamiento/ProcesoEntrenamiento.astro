---
import { pasosProcesoEntrenamiento } from "../../data/entrenamientoPersonal";

import PasoEntrenamientoCard from "./PasoEntrenamientoCard.astro";
---

<section id="proceso" class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2
        class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600"
      >
        Proceso de contacto
      </h2>
      <p class="mt-4 text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        Hacemos fácil empezar con el programa adecuado
      </p>
      <p class="mt-4 text-lg text-gray-500">
        Te orientamos antes de apuntarte para que el entrenamiento tenga sentido
        para tu momento, tu objetivo y tu disponibilidad.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        pasosProcesoEntrenamiento.map((paso, index) => (
          <PasoEntrenamientoCard paso={paso} index={index} />
        ))
      }
    </div>
  </div>
</section>
