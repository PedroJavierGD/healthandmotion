---
import Hero from "../Hero.astro";
import imagenEntrenamiento from "../../assets/images/entrenamiento-personal/Nuestros entrenadores personales en Sanlúcar de Barrameda _ Health & Mtion _ Clínica de Fisioterapia y Entrenamiento Personal.webp";
---

<Hero
  variant="blue"
  badge="Entrenamiento personal en Sanlúcar de Barrameda"
  badgeTag="h1"
  badgeColor="green"
  accentColor="primary"
  title="Entrena con seguridad y vuelve a sentirte bien"
  titleTag="p"
  highlight="vuelve a sentirte bien"
  subtitle="En Health & Motion trabajamos el entrenamiento personal desde un enfoque clínico, con programas para embarazo, post parto, espalda y rehabilitación adaptados a tu momento."
  subtitleHtml="En Health & Motion trabajamos el <strong>entrenamiento personal en Sanlúcar</strong> desde un enfoque clínico, con programas para embarazo, post parto, espalda y rehabilitación adaptados a tu momento."
  image={imagenEntrenamiento}
  imageAlt="Entrenamiento personal en Health and Motion"
  imageBadgeTitle="Entrenamiento Guiado"
  imageBadgeSubtitle="En clínica"
  ctaText="Quiero precio e información"
  ctaHref="#contacto"
  showSecondaryCta={false}
  stats={[]}
  features={[
    { text: "Grupos reducidos", checked: true },
    { text: "Enfoque clínico", checked: true },
    { text: "Programas adaptados", checked: true },
  ]}
/>
