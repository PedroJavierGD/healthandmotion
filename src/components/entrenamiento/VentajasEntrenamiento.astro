---
import { ventajasEntrenamiento } from "../../data/entrenamientoPersonal";

import VentajaEntrenamientoCard from "./VentajaEntrenamientoCard.astro";
---

<section id="ventajas" class="bg-gray-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-gray-900">
        ¿Por qué elegir nuestro entrenamiento personal en Sanlúcar?
      </h2>
      <p class="mt-4 max-w-3xl mx-auto text-lg text-gray-500">
        Si vienes con dolor, embarazo, post parto o una lesión, necesitas algo
        más que una rutina. Trabajamos desde la adaptación, la seguridad y el
        acompañamiento profesional.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        ventajasEntrenamiento.map((ventaja) => (
          <VentajaEntrenamientoCard ventaja={ventaja} />
        ))
      }
    </div>
  </div>
</section>
