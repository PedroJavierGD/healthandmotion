---
import { programasEntrenamiento } from "../../data/entrenamientoPersonal";

import ProgramaEntrenamientoCard from "./ProgramaEntrenamientoCard.astro";
---

<section id="programas" class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="text-primary-600 font-semibold tracking-wide uppercase text-sm"
      >
        Programas de entrenamiento
      </h2>
      <p class="mt-2 text-3xl sm:text-4xl font-heading font-bold text-gray-900">
        Cada necesidad tiene su propia sección dentro de la clínica
      </p>
      <p class="mt-4 max-w-3xl mx-auto text-xl text-gray-500">
        No ofrecemos un entrenamiento genérico. Organizamos grupos concretos
        para etapas y necesidades distintas, con el objetivo de mejorar salud,
        funcionalidad y adherencia.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {
        programasEntrenamiento.map((programa) => (
          <ProgramaEntrenamientoCard programa={programa} />
        ))
      }
    </div>
  </div>
</section>
