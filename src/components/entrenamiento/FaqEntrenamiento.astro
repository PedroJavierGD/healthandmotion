---
import { faqEntrenamiento } from "../../data/entrenamientoPersonal";

import FaqEntrenamientoItem from "./FaqEntrenamientoItem.astro";
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <div
        class="inline-flex rounded-full bg-primary-100 px-4 py-2 text-sm font-semibold text-primary-700"
      >
        Preguntas frecuentes
      </div>
      <h2 class="mt-4 text-3xl font-bold text-gray-900 sm:text-4xl">
        Resolvemos las dudas más habituales
      </h2>
    </div>

    <div class="mt-12 space-y-4">
      {
        faqEntrenamiento.map((item) => <FaqEntrenamientoItem item={item} />)
      }
    </div>
  </div>
</section>
