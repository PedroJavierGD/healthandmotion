---
import { faqEntrenamiento } from "../../data/entrenamientoPersonal";

import FaqEntrenamientoItem from "./FaqEntrenamientoItem.astro";
---

<section id="preguntas-frecuentes" class="py-24 bg-white">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1.5 bg-accent-100 text-accent-700 font-semibold tracking-wide uppercase text-sm rounded-full">
        FAQ
      </span>
      <h2 class="mt-6 text-4xl sm:text-5xl font-heading font-bold text-gray-900">
        Preguntas frecuentes
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Resolvemos las dudas más habituales antes de pedir información.
      </p>
    </div>

    <div class="space-y-4">
      {
        faqEntrenamiento.map((item) => <FaqEntrenamientoItem item={item} />)
      }
    </div>
  </div>
</section>
