---
import type { FaqEntrenamiento } from "../../data/entrenamientoPersonal";

interface Props {
  item: FaqEntrenamiento;
}

const { item } = Astro.props;
const parrafosRespuesta = item.respuesta.split("\n\n");
---

<details class="group rounded-2xl border border-gray-200 bg-gray-50 p-6 shadow-sm">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left">
    <span class="text-lg font-semibold text-gray-900">{item.pregunta}</span>
    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-100 text-accent-700 transition-transform duration-300 group-open:rotate-45">
      +
    </span>
  </summary>
  <div class="mt-4 pr-10 space-y-4 text-gray-600">
    {
      parrafosRespuesta.map((parrafo) => (
        <p>{parrafo}</p>
      ))
    }
  </div>
</details>
