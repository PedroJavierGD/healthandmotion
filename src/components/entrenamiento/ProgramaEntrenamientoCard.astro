---
import {
  ArrowRight,
  CalendarDays,
  Clock3,
  Dumbbell,
  HeartHandshake,
  Target,
  Users,
} from "@lucide/astro";

import type { ProgramaEntrenamiento } from "../../data/entrenamientoPersonal";

interface Props {
  programa: ProgramaEntrenamiento;
}

const { programa } = Astro.props;

const iconMap = {
  "heart-handshake": HeartHandshake,
  users: Users,
  target: Target,
  dumbbell: Dumbbell,
};

const Icon = iconMap[programa.icon];
---

<article
  id={programa.slug}
  class:list={[
    "rounded-[2rem] border p-8 shadow-lg transition hover:-translate-y-1 hover:shadow-2xl",
    programa.featured
      ? "border-accent-200 bg-gradient-to-br from-accent-50 to-white"
      : "border-primary-100 bg-gradient-to-br from-white to-primary-50/70",
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="inline-flex rounded-full bg-white px-4 py-2 text-sm font-semibold text-primary-700 shadow-sm">
        {programa.nombre}
      </div>
      <h3 class="mt-5 text-2xl font-bold text-gray-900">{programa.precio}</h3>
    </div>
    <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary-600 text-white shadow-md">
      <Icon class="h-7 w-7" aria-hidden="true" />
    </div>
  </div>

  <p class="mt-5 text-base leading-7 text-gray-600">{programa.descripcion}</p>

  <div class="mt-6 grid gap-3 sm:grid-cols-2">
    <div class="flex items-center gap-3 rounded-2xl bg-white px-4 py-3 shadow-sm">
      <Clock3 class="h-5 w-5 text-primary-600" aria-hidden="true" />
      <div>
        <div class="text-xs uppercase tracking-wide text-gray-400">Duración</div>
        <div class="font-semibold text-gray-900">{programa.duracion}</div>
      </div>
    </div>
    <div class="flex items-center gap-3 rounded-2xl bg-white px-4 py-3 shadow-sm">
      <CalendarDays class="h-5 w-5 text-primary-600" aria-hidden="true" />
      <div>
        <div class="text-xs uppercase tracking-wide text-gray-400">
          Frecuencia
        </div>
        <div class="font-semibold text-gray-900">{programa.frecuencia}</div>
      </div>
    </div>
  </div>

  <a
    href="#contacto"
    class="mt-6 inline-flex items-center text-base font-semibold text-accent-600 transition hover:text-accent-700"
  >
    Quiero información sobre este programa
    <ArrowRight class="ml-2 h-4 w-4" aria-hidden="true" />
  </a>
</article>
