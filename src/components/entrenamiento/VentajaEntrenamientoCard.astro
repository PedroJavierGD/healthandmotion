---
import {
  BadgeCheck,
  HeartHandshake,
  Target,
  Users,
} from "@lucide/astro";

import type { VentajaEntrenamiento } from "../../data/entrenamientoPersonal";

interface Props {
  ventaja: VentajaEntrenamiento;
}

const { ventaja } = Astro.props;

const iconMap = {
  "heart-handshake": HeartHandshake,
  users: Users,
  target: Target,
  "badge-check": BadgeCheck,
};

const Icon = iconMap[ventaja.icon];
---

<article class="rounded-3xl border border-primary-100 bg-white p-7 text-center shadow-[0_18px_45px_rgba(47,60,46,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_55px_rgba(47,60,46,0.1)]">
  <div
    class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-100 text-primary-700"
  >
    <Icon class="h-6 w-6" aria-hidden="true" />
  </div>
  <h3 class="mt-5 text-lg font-semibold text-gray-900">{ventaja.titulo}</h3>
  <p class="mt-3 text-sm leading-6 text-gray-500">{ventaja.texto}</p>
</article>
