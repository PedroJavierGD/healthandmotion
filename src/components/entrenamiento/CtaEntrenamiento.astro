<section id="contacto" class="bg-gradient-to-r from-primary-600 to-ink-900 py-20">
  <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      ¿Quieres entrenar con nosotros?
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">
      Pide información sobre el taller o grupo que más encaja contigo y te
      diremos precio, disponibilidad y cómo empezar.
    </p>
    <div class="mt-8 mx-auto max-w-lg rounded-2xl bg-white p-8 shadow-2xl">
      <form class="space-y-4">
        <input
          type="text"
          placeholder="Tu nombre"
          class="w-full rounded-lg border border-gray-300 px-4 py-3 outline-none transition focus:border-primary-500 focus:ring-2 focus:ring-primary-200"
          required
        />
        <input
          type="tel"
          placeholder="Tu teléfono"
          class="w-full rounded-lg border border-gray-300 px-4 py-3 outline-none transition focus:border-primary-500 focus:ring-2 focus:ring-primary-200"
          required
        />
        <select class="w-full rounded-lg border border-gray-300 px-4 py-3 outline-none transition focus:border-primary-500 focus:ring-2 focus:ring-primary-200">
          <option value="">¿Qué programa te interesa?</option>
          <option value="taller-de-embarazo">Taller de embarazo</option>
          <option value="taller-post-parto">Taller post parto</option>
          <option value="escuela-de-espalda">Escuela de espalda</option>
          <option value="grupo-de-rehabilitacion">Grupo de rehabilitación</option>
          <option value="asesoramiento">No lo tengo claro</option>
        </select>
        <button
          type="submit"
          class="w-full rounded-lg bg-accent-500 py-4 text-lg font-bold text-white shadow-md transition hover:bg-accent-600 hover:shadow-lg"
        >
          Solicitar información
        </button>
        <p class="text-center text-xs text-gray-400">
          Te responderemos para indicarte precio, horario y grupo adecuado.
        </p>
      </form>
    </div>
  </div>
</section>
