---
import { Brain, MonitorSmartphone, Shield, Users } from "@lucide/astro";

const ventajas = [
  {
    titulo: "Atención personalizada",
    descripcion:
      "Cada sesión se adapta a tu historia, tu situación actual y tus objetivos terapéuticos.",
    icono: Brain,
  },
  {
    titulo: "Espacio confidencial",
    descripcion:
      "Un entorno profesional y seguro para hablar con libertad y sentirte acompañado.",
    icono: Shield,
  },
  {
    titulo: "Visión integral",
    descripcion:
      "Si lo necesitas, podemos coordinar el proceso con otros servicios del centro como nutrición o fisioterapia.",
    icono: Users,
  },
  {
    titulo: "Sesiones presenciales y online",
    descripcion:
      "Nos adaptamos a tu disponibilidad para que cuidar tu salud mental sea más fácil y sostenible.",
    icono: MonitorSmartphone,
  },
];
---

<section class="bg-gray-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        Ventajas de empezar tu proceso con nuestra psicóloga
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-gray-600">
        Te ofrecemos una atención psicológica cuidada, cercana y pensada para
        que puedas avanzar con seguridad.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        ventajas.map((ventaja) => (
          <article class="rounded-3xl border border-primary-100 bg-white p-7 text-center shadow-[0_18px_45px_rgba(47,60,46,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_55px_rgba(47,60,46,0.1)]">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-100">
              <ventaja.icono
                class="h-8 w-8 text-primary-600"
                aria-hidden="true"
              />
            </div>
            <p class="mt-5 text-lg font-semibold text-gray-900">
              {ventaja.titulo}
            </p>
            <p class="mt-3 text-sm leading-6 text-gray-500">
              {ventaja.descripcion}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
