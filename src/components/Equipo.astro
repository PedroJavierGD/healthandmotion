  }
];

const filasEquipo = [
  equipo.slice(0, 5),
  equipo.slice(5, 10),
  equipo.slice(10, 13)
];
---

<section id="equipo" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-4">
      {filasEquipo.map((fila) => (
        <div class={`grid gap-3 ${fila.length === 3 ? 'grid-cols-3 max-w-3xl mx-auto' : 'grid-cols-2 md:grid-cols-5'}`}>
          {fila.map((persona) => (
            <div class="group text-center">
              <div class="relative overflow-hidden rounded-xl aspect-[4/5] bg-white">
                <img
                  src={persona.foto}
                  alt={persona.nombre}
                  class="w-full h-full object-contain object-center transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <h3 class="mt-3 text-base font-semibold text-gray-900">{persona.nombre}</h3>
              <p class="mt-2 text-sm font-medium text-primary-700">{persona.puesto}</p>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
