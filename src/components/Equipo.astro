---
const fotosLocales = import.meta.glob("../assets/images/*.webp", {
  eager: true,
  import: "default",
});

const normalizarTexto = (texto) =>
  texto
    .normalize("NFD")
    .replace(/\p{Diacritic}/gu, "")
    .replace(/[^a-zA-Z0-9]/g, "")
    .toLowerCase();

const buscarFotoEquipo = (terminos) => {
  const terminosNormalizados = terminos.map(normalizarTexto);

  return Object.entries(fotosLocales).find(([ruta]) => {
    const rutaNormalizada = normalizarTexto(ruta);
    return terminosNormalizados.every((termino) =>
      rutaNormalizada.includes(termino),
    );
  })?.[1];
};

const obtenerSrcFoto = (foto) =>
  typeof foto === "string" ? foto : (foto?.src ?? "");

const equipo = [
  {
    nombre: "Lorena",
    puesto: "Fisioterapeuta",
    foto: buscarFotoEquipo(["lorena", "fisioterapeuta"]),
  },
  {
    nombre: "Leire",
    puesto: "Fisioterapeuta",
    foto: buscarFotoEquipo(["leire", "fisioterapeuta"]),
  },
  {
    nombre: "Jose",
    puesto: "Fisioterapeuta",
    foto: "https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400&h=500&fit=crop&crop=face",
  },
  {
    nombre: "Carlos",
    puesto: "Entrenador Personal",
    foto: buscarFotoEquipo(["carlos", "entrenador personal"]),
  },
  {
    nombre: "Andrea",
    puesto: "Entrenadora Personal",
    foto: buscarFotoEquipo(["andrea", "entrenadora personal"]),
  },
  {
    nombre: "Pablo",
    puesto: "Entrenador Personal",
    foto: buscarFotoEquipo(["pablo", "entrenador personal"]),
  },
  {
    nombre: "Ángel",
    puesto: "Entrenador Personal",
    foto: buscarFotoEquipo(["angel", "entrenador personal"]),
  },
  {
    nombre: "Manu",
    puesto: "Entrenador Personal",
    foto: buscarFotoEquipo(["manu", "entrenador personal"]),
  },
  {
    nombre: "Fabi",
    puesto: "Entrenadora Personal",
    foto: buscarFotoEquipo(["fabi", "entrenadora personal"]),
  },
  {
    nombre: "?????????",
    puesto: "Nutricionista",
    foto: buscarFotoEquipo(["nutricionista"]),
  },
  {
    nombre: "?????????",
    puesto: "Psicóloga",
    foto: buscarFotoEquipo(["psicologa"]),
  },
  {
    nombre: "Eli",
    puesto: "Esteticista",
    foto: buscarFotoEquipo(["eli", "esteticista"]),
  },
  {
    nombre: "Cristina",
    puesto: "Recepcionista",
    foto: buscarFotoEquipo(["recepcionista"]),
  },
];

const filasEquipo = [
  equipo.slice(0, 5),
  equipo.slice(5, 10),
  equipo.slice(10, 13),
];
---

<section id="equipo" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-4">
      {
        filasEquipo.map((fila) => (
          <div
            class={`grid gap-3 ${fila.length === 3 ? "grid-cols-3 max-w-3xl mx-auto" : "grid-cols-2 md:grid-cols-5"}`}
          >
            {fila.map((persona) => (
              <div class="group text-center">
                <div class="relative overflow-hidden rounded-xl aspect-[4/5] bg-white">
                  <img
                    src={obtenerSrcFoto(persona.foto)}
                    alt={persona.nombre}
                    class="w-full h-full object-contain object-center transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-3 text-base font-semibold text-gray-900">
                  {persona.nombre}
                </h3>
                <p class="mt-2 text-sm font-medium text-primary-700">
                  {persona.puesto}
                </p>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>
