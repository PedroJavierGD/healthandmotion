---
const fotosLocales = import.meta.glob("../assets/images/*Health&Motion.webp", {
  eager: true,
  import: "default"
});

const normalizarTexto = (texto) =>
  texto.normalize("NFD").replace(/\p{Diacritic}/gu, "").toLowerCase();

const buscarFotoEquipo = (terminos) => {
  const terminosNormalizados = terminos.map(normalizarTexto);

  return Object.entries(fotosLocales).find(([ruta]) => {
    const rutaNormalizada = normalizarTexto(ruta);
    return terminosNormalizados.every((termino) => rutaNormalizada.includes(termino));
  })?.[1];
};

const obtenerSrcFoto = (foto) => (typeof foto === "string" ? foto : foto?.src ?? "");

const equipo = [
  {
    nombre: "Lorena",
    puesto: "Fisioterapeuta",
    foto:
      buscarFotoEquipo(["lorena", "fisioterapeuta"]) ??
      "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Leire",
    puesto: "Fisioterapeuta",
    foto:
      buscarFotoEquipo(["leire", "fisioterapeuta"]) ??
      "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Andrea Castillo",
    puesto: "Fisioterapeuta",
    foto: "https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Carlos",
    puesto: "Entrenador Personal",
    foto:
      buscarFotoEquipo(["carlos", "entrenador personal"]) ??
      "https://images.unsplash.com/photo-1567013127542-490d757e51fc?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Andrea",
    puesto: "Entrenadora Personal",
    foto:
      buscarFotoEquipo(["andrea", "entrenadora personal"]) ??
      "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Pablo",
    puesto: "Entrenador Personal",
    foto:
      buscarFotoEquipo(["pablo", "entrenador personal"]) ??
      "https://images.unsplash.com/photo-1594381898411-846e7d193883?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Ángel",
    puesto: "Entrenador Personal",
    foto:
      buscarFotoEquipo(["angel", "entrenador personal"]) ??
      "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Manu",
    puesto: "Entrenador Personal",
    foto:
      buscarFotoEquipo(["manu", "entrenador personal"]) ??
      "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Fabi",
    puesto: "Entrenadora Personal",
    foto:
      buscarFotoEquipo(["fabi", "entrenador personal"]) ??
      "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=400&h=500&fit=crop&crop=face"
  },
  {
    nombre: "Ana González",
    puesto: "Nutricionista",
    foto: "https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400&h=500&fit=crop&crop=face"
