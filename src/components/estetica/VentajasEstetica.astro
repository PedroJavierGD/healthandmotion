---
import { ventajasEstetica } from "../../data/estetica";

import VentajaEsteticaCard from "./VentajaEsteticaCard.astro";
---

<section id="ventajas" class="bg-gray-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        ¿Por qué elegir nuestra esteticista en Sanlúcar?
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-gray-500">
        Te ofrecemos un servicio de estética pensado para cuidar resultados,
        experiencia y trato personal.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        ventajasEstetica.map((ventaja) => (
          <VentajaEsteticaCard ventaja={ventaja} />
        ))
      }
    </div>
  </div>
</section>
