---
import { pasosProcesoEstetica } from "../../data/estetica";

import PasoEsteticaCard from "./PasoEsteticaCard.astro";
---

<section id="proceso" class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600">
        Cómo trabajamos
      </h2>
      <p class="mt-4 text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        Así es el proceso de las sesiones de estética
      </p>
      <p class="mt-4 text-lg text-gray-500">
        Buscamos que cada tratamiento tenga sentido para tu piel, tu momento y
        el resultado que quieres conseguir.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        pasosProcesoEstetica.map((paso, index) => (
          <PasoEsteticaCard paso={paso} index={index} />
        ))
      }
    </div>
  </div>
</section>
