---
import imagenCentroEstetica from "../../assets/images/centro-estetica-sanlucar-barrameda.webp";

const imagenes = [
  {
    src: imagenCentroEstetica.src,
    alt: "Cabina de estética en Health and Motion",
    clase: "md:col-span-2 md:row-span-2",
  },
  {
    src: "https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&w=900&q=80",
    alt: "Zona de tratamiento estético con ambiente cuidado y relajante",
    clase: "",
  },
  {
    src: "https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&w=900&q=80",
    alt: "Cabina preparada para tratamientos faciales y cuidado de la piel",
    clase: "",
  },
  {
    src: "https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=1400&q=80",
    alt: "Espacio de estética pensado para una experiencia cómoda y personalizada",
    clase: "md:col-span-2",
  },
];

const espacios = [
  {
    titulo: "Ambiente relajado",
    descripcion:
      "Un entorno pensado para que disfrutes la sesión y vivas el tratamiento con calma.",
    valor: "100%",
  },
  {
    titulo: "Cabina cuidada",
    descripcion:
      "Espacio preparado para tratamientos faciales y corporales con comodidad y privacidad.",
    valor: "1",
  },
  {
    titulo: "Atención personal",
    descripcion:
      "Cada sesión se enfoca en tus necesidades reales y en el estado concreto de tu piel.",
    valor: "Real",
  },
];
---

<section id="cabina" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-semibold uppercase tracking-wide text-primary-700">
        Conoce nuestra cabina
      </h2>
      <p class="mt-6 text-4xl font-heading font-bold text-gray-900 sm:text-5xl">
        Un espacio preparado para que
        <span class="text-primary-600"> te cuides con comodidad</span>
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
        Cuidamos el entorno de la cabina para que cada tratamiento de estética
        se realice en un ambiente agradable, profesional y tranquilo.
      </p>
    </div>

    <div class="mt-14 grid auto-rows-[250px] grid-cols-1 gap-4 md:grid-cols-4">
      {
        imagenes.map((imagen, index) => (
          <div class={`group relative overflow-hidden rounded-2xl ${imagen.clase}`}>
            <img
              src={imagen.src}
              alt={imagen.alt}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading={index < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute bottom-0 left-0 right-0 translate-y-4 p-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
              <p class="text-white font-medium">{imagen.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        espacios.map((espacio) => (
          <article class="rounded-2xl border border-gray-100 bg-gray-50 p-8 text-center shadow-sm">
            <div class="text-4xl font-heading font-extrabold text-primary-600">
              {espacio.valor}
            </div>
            <p class="mt-4 text-xl font-bold text-gray-900">
              {espacio.titulo}
            </p>
            <p class="mt-2 text-gray-600">{espacio.descripcion}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
