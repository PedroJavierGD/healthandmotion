---
import { Heart, Shield, Sparkles, Users } from "@lucide/astro";
import imagenEsteticista from "../../assets/images/Eli - Esteticista en Health&Motion.webp";

const pilares = [
  {
    titulo: "Valoración personalizada",
    descripcion:
      "Observamos tu piel, tus necesidades y tu objetivo antes de recomendar el tratamiento más adecuado.",
    icono: Sparkles,
  },
  {
    titulo: "Cuidado profesional",
    descripcion:
      "Trabajamos con un enfoque cuidadoso para ayudarte a mejorar el aspecto de tu piel de forma progresiva.",
    icono: Shield,
  },
  {
    titulo: "Bienestar y estética",
    descripcion:
      "Buscamos que cada sesión te ayude a verte mejor y también a disfrutar de un momento para ti.",
    icono: Heart,
  },
  {
    titulo: "Atención cercana",
    descripcion:
      "Te acompañamos con un trato humano, resolviendo dudas y ajustando el trabajo según tu evolución.",
    icono: Users,
  },
];
---

<section id="esteticista" class="bg-white py-24">
  <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:px-8">
    <div class="relative overflow-hidden rounded-[2rem] border border-gray-200 bg-gray-50 shadow-xl">
      <img
        src={imagenEsteticista.src}
        alt="Esteticista de Health and Motion en Sanlúcar de Barrameda"
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/5 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
        <div class="inline-flex rounded-full bg-white/90 px-4 py-2 text-sm font-semibold text-primary-700 shadow-sm">
          Estética facial y corporal
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center">
      <span class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-semibold uppercase tracking-wide text-primary-700">
        Conoce a nuestra esteticista
      </span>
      <h2 class="mt-6 text-4xl font-heading font-bold text-gray-900 sm:text-5xl">
        Un servicio de estética
        <span class="text-primary-600"> pensado para cuidar tu piel y tu confianza</span>
      </h2>
      <p class="mt-5 text-lg leading-8 text-gray-600">
        Nuestro servicio de estética está enfocado en ayudarte a mejorar el
        aspecto de tu piel, cuidar tu rostro y tu cuerpo, y adaptar cada sesión
        a lo que realmente necesitas en este momento.
      </p>
      <p class="mt-4 text-lg leading-8 text-gray-600">
        No todas las pieles ni todos los objetivos son iguales. Por eso
        trabajamos desde una atención personalizada, combinando valoración,
        cuidado profesional y una experiencia agradable para que cada sesión
        tenga sentido para ti.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          pilares.map((pilar) => (
            <article class="rounded-3xl border border-gray-200 bg-gray-50 p-5 shadow-sm">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary-100 text-primary-700">
                <pilar.icono class="h-6 w-6" aria-hidden="true" />
              </div>
              <p class="mt-4 text-lg font-semibold text-gray-900">
                {pilar.titulo}
              </p>
              <p class="mt-2 text-sm leading-6 text-gray-600">
                {pilar.descripcion}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
