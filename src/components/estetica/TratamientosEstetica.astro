---
import { tratamientosEstetica } from "../../data/estetica";

import TratamientoEsteticaCard from "./TratamientoEsteticaCard.astro";
---

<section id="tratamientos" class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-primary-600">
        Tipos de tratamientos de estética
      </h2>
      <p class="mt-2 text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        Te ayudamos a cuidar tu piel con el tratamiento que mejor encaja contigo
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-xl text-gray-500">
        Ofrecemos distintas sesiones de estética para responder a necesidades
        faciales y corporales con una atención personalizada y cuidada.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        tratamientosEstetica.map((tratamiento) => (
          <TratamientoEsteticaCard tratamiento={tratamiento} />
        ))
      }
    </div>
  </div>
</section>
