---
const imagenes = [
  {
    src: "https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=1400&q=80",
    alt: "Gabinete de psicología con sillones cómodos y ambiente cálido",
    clase: "md:col-span-2 md:row-span-2",
  },
  {
    src: "https://images.unsplash.com/photo-1517022812141-23620dba5c23?auto=format&fit=crop&w=900&q=80",
    alt: "Detalle del espacio de consulta preparado para sesiones individuales",
    clase: "",
  },
  {
    src: "https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&w=900&q=80",
    alt: "Sala tranquila y cuidada para terapia presencial",
    clase: "",
  },
  {
    src: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1400&q=80",
    alt: "Zona de espera y gabinete de psicología en Health and Motion",
    clase: "md:col-span-2",
  },
];

const espacios = [
  {
    titulo: "Ambiente tranquilo",
    descripcion:
      "Un espacio pensado para que puedas hablar con calma y sin interrupciones.",
    valor: "100%",
  },
  {
    titulo: "Consulta cuidada",
    descripcion:
      "Mobiliario cómodo, luz agradable y un entorno que favorece el bienestar.",
    valor: "1",
  },
  {
    titulo: "Privacidad",
    descripcion:
      "La confidencialidad y la sensación de seguridad forman parte del propio espacio.",
    valor: "Máxima",
  },
];
---

<section id="gabinete" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-semibold uppercase tracking-wide text-primary-700">
        Conoce nuestro gabinete
      </h2>
      <p class="mt-6 text-4xl font-heading font-bold text-gray-900 sm:text-5xl">
        Un espacio diseñado para que
        <span class="text-primary-600"> te sientas cómodo desde el primer día</span>
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
        Cuidamos el entorno para que cada sesión de psicología se desarrolle en
        un ambiente íntimo, tranquilo y acogedor.
      </p>
    </div>

    <div class="mt-14 grid auto-rows-[250px] grid-cols-1 gap-4 md:grid-cols-4">
      {
        imagenes.map((imagen, index) => (
          <div class={`group relative overflow-hidden rounded-2xl ${imagen.clase}`}>
            <img
              src={imagen.src}
              alt={imagen.alt}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading={index < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute bottom-0 left-0 right-0 translate-y-4 p-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
              <p class="text-white font-medium">{imagen.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        espacios.map((espacio) => (
          <article class="rounded-2xl border border-gray-100 bg-gray-50 p-8 text-center shadow-sm">
            <div class="text-4xl font-heading font-extrabold text-primary-600">
              {espacio.valor}
            </div>
            <p class="mt-4 text-xl font-bold text-gray-900">
              {espacio.titulo}
            </p>
            <p class="mt-2 text-gray-600">{espacio.descripcion}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
