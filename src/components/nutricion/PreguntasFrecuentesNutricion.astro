---
import { faqNutricion } from "../../data/nutricion";

import PreguntaFrecuenteNutricionItem from "./PreguntaFrecuenteNutricionItem.astro";
---

<section id="preguntas-frecuentes" class="bg-white py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <span class="inline-block rounded-full bg-accent-100 px-4 py-1.5 text-sm font-semibold uppercase tracking-wide text-accent-700">
        FAQ
      </span>
      <h2 class="mt-6 text-4xl font-heading font-bold text-gray-900 sm:text-5xl">
        Preguntas frecuentes sobre nutrición
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Respondemos algunas dudas habituales antes de reservar tu consulta.
      </p>
    </div>

    <div class="space-y-4">
      {
        faqNutricion.map((item, index) => (
          <PreguntaFrecuenteNutricionItem item={item} open={index === 0} />
        ))
      }
    </div>
  </div>
</section>
