---
import type { FaqNutricion } from "../../data/nutricion";

interface Props {
  item: FaqNutricion;
  open?: boolean;
}

const { item, open = false } = Astro.props;
const parrafos = item.respuesta.split("\n\n").filter(Boolean);
---

<details
  class="group rounded-2xl border border-gray-200 bg-gray-50 p-6 shadow-sm"
  open={open}
>
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left">
    <h3 class="text-lg font-semibold text-gray-900">{item.pregunta}</h3>
    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-100 text-accent-700 transition-transform duration-300 group-open:rotate-45">
      +
    </span>
  </summary>
  <div class="mt-4 space-y-4 pr-10 text-gray-600">
    {parrafos.map((parrafo) => (
      <p>{parrafo}</p>
    ))}
  </div>
</details>
