---
import { consultasNutricion } from "../../data/nutricion";

import ConsultaNutricionCard from "./ConsultaNutricionCard.astro";
---

<section id="consultas" class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-primary-600">
        Tipos de consultas de nutrición
      </h2>
      <p class="mt-2 text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        Trabajamos objetivos y necesidades nutricionales diferentes
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-xl text-gray-500">
        Adaptamos el enfoque a tu caso para que la alimentación se convierta en
        una herramienta real de salud, rendimiento y bienestar.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        consultasNutricion.map((consulta) => (
          <ConsultaNutricionCard consulta={consulta} />
        ))
      }
    </div>
  </div>
</section>
