---
import imagenConsulta from "../../assets/images/nutricionista/dietista-nutricionista-consulta-sanlucar-barrameda.webp";
import imagenDeportistas from "../../assets/images/nutricionista/dietista-nutricionista-deportistas-sanlucar-barrameda.webp";
import imagenNutricionista from "../../assets/images/nutricionista/nutricionista-sanlucar-barrameda.webp";
import imagenSeguimiento from "../../assets/images/nutricionista/nutricionista-consulta-sanlucar-barrameda.webp";

const imagenes = [
  {
    src: imagenNutricionista.src,
    alt: "Nutricionista en consulta en Health and Motion",
    clase: "md:col-span-2 md:row-span-2",
  },
  {
    src: imagenDeportistas.src,
    alt: "Nutrición deportiva con dietista nutricionista en Sanlúcar",
    clase: "",
  },
  {
    src: imagenConsulta.src,
    alt: "Consulta con dietista nutricionista en Sanlúcar de Barrameda",
    clase: "",
  },
  {
    src: imagenSeguimiento.src,
    alt: "Seguimiento nutricional personalizado en consulta",
    clase: "md:col-span-2",
  },
];

const espacios = [
  {
    titulo: "Entorno cómodo",
    descripcion:
      "Una consulta tranquila para hablar de hábitos, objetivos y seguimiento con cercanía.",
    valor: "100%",
  },
  {
    titulo: "Apoyo visual y práctico",
    descripcion:
      "Trabajamos con material que te ayude a entender mejor tus pautas y aplicarlas en casa.",
    valor: "1",
  },
  {
    titulo: "Atención personalizada",
    descripcion:
      "Cada revisión se centra en tu evolución y en lo que de verdad necesitas ajustar.",
    valor: "Real",
  },
];
---

<section id="gabinete" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-semibold uppercase tracking-wide text-primary-700">
        Conoce nuestra consulta
      </h2>
      <p class="mt-6 text-4xl font-heading font-bold text-gray-900 sm:text-5xl">
        Un espacio donde trabajar tu alimentación
        <span class="text-primary-600"> con claridad y sin presión</span>
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
        Hemos cuidado la consulta para que puedas abordar tu proceso de
        nutrición en un entorno cómodo, práctico y cercano.
      </p>
    </div>

    <div class="mt-14 grid auto-rows-[250px] grid-cols-1 gap-4 md:grid-cols-4">
      {
        imagenes.map((imagen, index) => (
          <div class={`group relative overflow-hidden rounded-2xl ${imagen.clase}`}>
            <img
              src={imagen.src}
              alt={imagen.alt}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading={index < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute bottom-0 left-0 right-0 translate-y-4 p-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
              <p class="text-white font-medium">{imagen.alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        espacios.map((espacio) => (
          <article class="rounded-2xl border border-gray-100 bg-gray-50 p-8 text-center shadow-sm">
            <div class="text-4xl font-heading font-extrabold text-primary-600">
              {espacio.valor}
            </div>
            <p class="mt-4 text-xl font-bold text-gray-900">
              {espacio.titulo}
            </p>
            <p class="mt-2 text-gray-600">{espacio.descripcion}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
