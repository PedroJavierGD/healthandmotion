---
const pasos = [
  {
    numero: "1.",
    titulo: "Valoración inicial",
    descripcion:
      "Hablamos de tus hábitos, tu objetivo, tu historial y el contexto real en el que comes cada día.",
  },
  {
    numero: "2.",
    titulo: "Diseño del plan",
    descripcion:
      "Preparamos una pauta personalizada con recomendaciones prácticas, estructura y objetivos claros.",
  },
  {
    numero: "3.",
    titulo: "Aplicación a tu rutina",
    descripcion:
      "Adaptamos la estrategia a tus horarios, gustos, nivel de actividad y necesidades para que sea sostenible.",
  },
  {
    numero: "4.",
    titulo: "Seguimiento y ajustes",
    descripcion:
      "Revisamos evolución, resolvemos dudas y hacemos cambios cuando hace falta para seguir avanzando.",
  },
];
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600">
        Cómo trabajamos
      </p>
      <h2 class="mt-4 text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        Así es el proceso de las consultas de nutrición
      </h2>
      <p class="mt-4 text-lg text-gray-500">
        Buscamos que entiendas el porqué de cada pauta y que el plan tenga
        sentido para tu vida, no solo para el papel.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        pasos.map((paso) => (
          <article class="rounded-3xl border border-accent-100 bg-gradient-to-br from-white to-accent-50 p-7 shadow-[0_20px_50px_rgba(93,18,22,0.08)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_26px_60px_rgba(93,18,22,0.14)]">
            <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-accent-500 text-lg font-bold text-white">
              {paso.numero}
            </div>
            <p class="text-xl font-heading font-bold text-gray-900">
              {paso.titulo}
            </p>
            <p class="mt-3 text-sm leading-6 text-gray-500">
              {paso.descripcion}
            </p>
          </article>
        ))
      }
    </div>

    <div class="mt-12 text-center">
      <a
        href="#contacto"
        class="inline-flex items-center justify-center rounded-xl bg-accent-500 px-8 py-4 text-lg font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-accent-600 hover:shadow-xl"
      >
        Solicitar primera consulta
      </a>
    </div>
  </div>
</section>
