---
import { ventajasNutricion } from "../../data/nutricion";

import VentajaNutricionCard from "./VentajaNutricionCard.astro";
---

<section id="ventajas" class="bg-gray-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
        ¿Por qué elegir nuestra nutricionista en Sanlúcar?
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-gray-500">
        Te ayudamos a conseguir resultados de forma ordenada, realista y
        sostenible, con un plan adaptado a tu contexto y un seguimiento cercano.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        ventajasNutricion.map((ventaja) => (
          <VentajaNutricionCard ventaja={ventaja} />
        ))
      }
    </div>
  </div>
</section>
