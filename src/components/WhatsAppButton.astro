---
const whatsappNumber = "34722664982";
const whatsappMessage = encodeURIComponent(
  "¡Hola Health&Motion! Vengo de vuestra web y me gustaría pedir una cita :)"
);
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<div class="whatsapp-widget fixed z-[70] flex items-end gap-3" data-whatsapp-widget>
  <div
    class="whatsapp-toast max-w-[220px] rounded-2xl bg-[#25D366] px-4 py-3 text-sm font-semibold text-white shadow-[0_16px_38px_rgba(37,211,102,0.28)] ring-1 ring-[#25D366]/30"
    data-whatsapp-toast
  >
    ¡Pide tu cita por WhatsApp ahora!
  </div>

  <a
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Hablar por WhatsApp para pedir cita o pedir más información"
    title="Hablar por WhatsApp para pedir cita o pedir más información"
    class="inline-flex h-14 w-14 items-center justify-center rounded-full border border-white/60 bg-[#25D366] text-white shadow-[0_18px_40px_rgba(37,211,102,0.28)] transition duration-200 hover:-translate-y-0.5 hover:bg-[#1ebe5b] hover:shadow-[0_22px_48px_rgba(37,211,102,0.34)] focus:outline-none focus:ring-4 focus:ring-[#25D366]/30 sm:h-16 sm:w-16"
    data-whatsapp-trigger
  >
    <svg
      viewBox="0 0 16 16"
      class="h-7 w-7 sm:h-8 sm:w-8"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M13.601 2.326A7.85 7.85 0 0 0 8.06 0C3.65 0 .073 3.576.073 7.986c0 1.408.369 2.782 1.068 3.99L0 16l4.146-1.086a7.98 7.98 0 0 0 3.914 1.065h.003c4.41 0 7.987-3.576 7.987-7.986a7.94 7.94 0 0 0-2.449-5.667ZM8.06 14.66a6.6 6.6 0 0 1-3.358-.92l-.24-.145-2.459.645.656-2.4-.156-.245a6.58 6.58 0 0 1-1.007-3.51c0-3.658 2.976-6.633 6.64-6.633a6.6 6.6 0 0 1 4.695 1.949 6.58 6.58 0 0 1 1.948 4.698c-.002 3.659-2.978 6.633-6.638 6.633Zm3.615-4.934c-.197-.1-1.17-.579-1.351-.646-.18-.066-.312-.099-.444.1-.132.198-.51.645-.625.778-.115.132-.23.149-.427.05-.197-.1-.833-.308-1.587-.98-.587-.523-.984-1.17-1.1-1.369-.115-.198-.012-.305.087-.404.09-.089.197-.23.296-.347.1-.116.132-.198.198-.33.066-.132.033-.248-.017-.347-.05-.099-.444-1.07-.608-1.466-.16-.387-.323-.335-.444-.341l-.378-.006a.72.72 0 0 0-.526.248c-.181.198-.69.675-.69 1.646 0 .97.707 1.908.806 2.04.099.132 1.393 2.128 3.377 2.982.472.204.84.326 1.127.417.473.15.904.129 1.245.078.38-.057 1.17-.479 1.335-.941.164-.463.164-.86.115-.942-.05-.083-.181-.132-.378-.231Z" />
    </svg>
    <span class="sr-only">Hablar por WhatsApp para pedir cita o pedir más información</span>
  </a>
</div>

<script is:inline>
  const whatsappWidget = document.querySelector("[data-whatsapp-widget]");
  const whatsappToast = document.querySelector("[data-whatsapp-toast]");
  const whatsappTrigger = document.querySelector("[data-whatsapp-trigger]");

  if (
    whatsappWidget instanceof HTMLElement &&
    whatsappToast instanceof HTMLElement &&
    whatsappTrigger instanceof HTMLElement
  ) {
    let hasShownScrollToast = false;
    let isTicking = false;
    let hideToastTimeoutId;

    const showToast = () => {
      whatsappToast.classList.add("is-visible");
    };

    const hideToast = () => {
      whatsappToast.classList.remove("is-visible");
    };

    const clearHideToastTimeout = () => {
      if (typeof hideToastTimeoutId === "number") {
        window.clearTimeout(hideToastTimeoutId);
        hideToastTimeoutId = undefined;
      }
    };

    const showToastTemporarily = () => {
      showToast();
      clearHideToastTimeout();
      hideToastTimeoutId = window.setTimeout(() => {
        hideToast();
        hideToastTimeoutId = undefined;
      }, 5000);
    };

    const revealToast = () => {
      if (hasShownScrollToast) {
        return;
      }

      const documentHeight =
        document.documentElement.scrollHeight - window.innerHeight;

      if (documentHeight <= 0) {
        return;
      }

      const scrollProgress = window.scrollY / documentHeight;

      if (scrollProgress >= 0.35) {
        hasShownScrollToast = true;
        showToastTemporarily();
        window.removeEventListener("scroll", onScroll);
      }
    };

    const onScroll = () => {
      if (isTicking) {
        return;
      }

      isTicking = true;
      window.requestAnimationFrame(() => {
        revealToast();
        isTicking = false;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    whatsappTrigger.addEventListener("mouseenter", () => {
      clearHideToastTimeout();
      showToast();
    });
    whatsappTrigger.addEventListener("mouseleave", () => {
      hideToast();
    });
    whatsappTrigger.addEventListener("focus", () => {
      clearHideToastTimeout();
      showToast();
    });
    whatsappTrigger.addEventListener("blur", () => {
      hideToast();
    });
    revealToast();
  }
</script>

<style>
  .whatsapp-widget {
    right: calc(1rem + env(safe-area-inset-right));
    bottom: calc(1rem + env(safe-area-inset-bottom));
  }

  .whatsapp-toast {
    opacity: 0;
    transform: translateY(12px) scale(0.96);
    transform-origin: bottom right;
    pointer-events: none;
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .whatsapp-toast.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (min-width: 640px) {
    .whatsapp-widget {
      right: calc(1.5rem + env(safe-area-inset-right));
      bottom: calc(1.5rem + env(safe-area-inset-bottom));
    }
  }
</style>
