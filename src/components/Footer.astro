---
import { Mail, MapPin, Phone } from "@lucide/astro";
import logo from "../assets/images/logotipo-health-and-motion.webp";

const servicios = [
  { label: "Entrenamiento Personal", href: "#" },
  { label: "Estética", href: "#" },
  { label: "Fisioterapia", href: "/fisioterapia" },
  { label: "Nutrición", href: "#" },
  { label: "Psicología", href: "#" },
];

const horario = [
  "Lunes - Viernes: 9:00 - 21:00",
  "Sábados: 9:00 - 14:00",
  "Domingos: Cerrado",
];
---

<footer class="bg-gray-900 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8">
      <div>
        <a
          href="/"
          class="inline-flex items-center"
          aria-label="Health and Motion"
        >
          <img
            src={logo.src}
            alt="Health and Motion"
            class="h-12 w-auto sm:h-14"
          />
        </a>
        <p class="mt-4 text-gray-400 text-sm">
          Tu centro médico multidisciplinar para entrenamiento, estética,
          fisioterapia, nutrición y psicología.
        </p>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Servicios</h4>
        <ul class="space-y-2 text-gray-400 text-sm">
          {
            servicios.map((servicio) => (
              <li>
                <a href={servicio.href} class="hover:text-white transition">
                  {servicio.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="font-semibold mb-4">Horario</p>
        <ul class="space-y-2 text-gray-400 text-sm">
          {horario.map((h) => <li>{h}</li>)}
        </ul>
      </div>

      <div>
        <p class="font-semibold mb-4">Contacto</p>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li class="flex items-center">
            <MapPin class="mr-2 h-4 w-4" aria-hidden="true" />
            Av. Cabo Noval, 45, 11540 Sanlúcar de Barrameda, Cádiz
          </li>
          <li class="flex items-center">
            <Phone class="mr-2 h-4 w-4" aria-hidden="true" />
            722 66 49 82
          </li>
          <li class="flex items-center">
            <Mail class="mr-2 h-4 w-4" aria-hidden="true" />
            centros.healthmotion@gmail.com
          </li>
        </ul>
      </div>
    </div>

    <div
      class="border-t border-gray-800 mt-12 pt-8 text-center text-gray-500 text-sm"
    >
      <p>&copy; 2026 Health & Motion. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
