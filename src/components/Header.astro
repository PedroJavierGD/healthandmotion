---
import { ChevronDown, Menu, Phone } from "@lucide/astro";
import logo from "../assets/images/logotipo-health-and-motion.webp";
import { mainNavItems } from "../data/navigation";

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

const {
  navItems = mainNavItems,
  ctaHref = "/#contacto"
} = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-4 h-20">
      <div class="flex items-center">
        <a href="/" class="flex items-center" aria-label="Health and Motion">
          <img
            src={logo.src}
            alt="Health and Motion"
            class="h-12 w-auto sm:h-14"
          />
        </a>
      </div>

      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          item.children ? (
            <div class="group relative">
              <a
                href={item.href}
                class="flex items-center gap-1 text-gray-600 hover:text-primary-600 font-medium transition"
              >
                {item.label}
                <ChevronDown class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true" />
              </a>

              <div class="pointer-events-none absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 pt-4 opacity-0 transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
                <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white p-2 shadow-xl">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block rounded-xl px-4 py-3 text-sm font-medium text-gray-600 transition hover:bg-primary-50 hover:text-primary-700"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="text-gray-600 hover:text-primary-600 font-medium transition">
              {item.label}
            </a>
          )
        ))}
      </nav>

      <div class="hidden md:flex items-center space-x-4">
        <a href="tel:+34722664982" class="hidden sm:flex items-center text-primary-700 font-semibold hover:text-primary-800 transition">
          <Phone class="mr-2 h-5 w-5" aria-hidden="true" />
          +34 722 66 49 82
        </a>
        <a href={ctaHref} class="bg-accent-500 hover:bg-accent-600 text-white px-5 py-2.5 rounded-lg font-semibold transition shadow-md hover:shadow-lg">
          Pedir Cita
        </a>
      </div>

      <details class="group relative md:hidden">
        <summary class="flex h-12 w-12 cursor-pointer list-none items-center justify-center rounded-2xl border border-gray-200 bg-white text-gray-700 shadow-sm transition hover:border-primary-200 hover:text-primary-700">
          <span class="sr-only">Abrir menú principal</span>
          <Menu class="h-6 w-6" aria-hidden="true" />
        </summary>

        <div class="absolute right-0 top-[calc(100%+0.75rem)] w-[min(22rem,calc(100vw-2rem))] rounded-3xl border border-gray-100 bg-white p-5 shadow-2xl">
          <nav class="flex flex-col gap-2">
            {navItems.map((item) => (
              item.children ? (
                <details class="group rounded-2xl bg-gray-50 px-4 py-3">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-3 font-semibold text-gray-700">
                    <span>{item.label}</span>
                    <ChevronDown class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" aria-hidden="true" />
                  </summary>

                  <div class="mt-3 flex flex-col gap-2 border-l border-primary-100 pl-4">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="rounded-xl px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white hover:text-primary-700"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </details>
              ) : (
                <a
                  href={item.href}
                  class="rounded-2xl px-4 py-3 font-semibold text-gray-700 transition hover:bg-gray-50 hover:text-primary-700"
                >
                  {item.label}
                </a>
              )
            ))}
          </nav>

          <div class="mt-5 border-t border-gray-100 pt-5">
            <a href="tel:+34722664982" class="flex items-center justify-center text-primary-700 font-semibold hover:text-primary-800 transition">
              <Phone class="mr-2 h-5 w-5" aria-hidden="true" />
              +34 722 66 49 82
            </a>
            <a href={ctaHref} class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-accent-500 px-5 py-3 font-semibold text-white shadow-md transition hover:bg-accent-600 hover:shadow-lg">
              Pedir Cita
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
