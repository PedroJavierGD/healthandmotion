---
import { ChevronDown, Phone } from '@lucide/astro';
import logo from '../assets/images/logotipo-health-and-motion.webp';

const serviciosItems = [
  { label: "Fisioterapia", href: "/clinica-de-fisioterapia-en-sanlucar-de-barrameda" },
  { label: "Entrenamiento Personal", href: "/#servicios" },
  { label: "Nutrición", href: "/#servicios" },
  { label: "Psicología", href: "/#servicios" },
  { label: "Estética", href: "/#servicios" }
];

const navItems = [
  { label: "Servicios", href: "/#servicios", children: serviciosItems },
  { label: "Nosotros", href: "/#nosotros" },
  { label: "Testimonios", href: "/#testimonios" },
  { label: "Contacto", href: "/#contacto" }
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex items-center">
        <a href="/" class="flex items-center" aria-label="Health and Motion">
          <img
            src={logo.src}
            alt="Health and Motion"
            class="h-12 w-auto sm:h-14"
          />
        </a>
      </div>
      
      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          item.children ? (
            <div class="group relative">
              <a
                href={item.href}
                class="flex items-center gap-1 text-gray-600 hover:text-primary-600 font-medium transition"
              >
                {item.label}
                <ChevronDown class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true" />
              </a>

              <div class="pointer-events-none absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 pt-4 opacity-0 transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
                <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white p-2 shadow-xl">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block rounded-xl px-4 py-3 text-sm font-medium text-gray-600 transition hover:bg-primary-50 hover:text-primary-700"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="text-gray-600 hover:text-primary-600 font-medium transition">
              {item.label}
            </a>
          )
        ))}
      </nav>

      <div class="flex items-center space-x-4">
        <a href="tel:+34722664982" class="hidden sm:flex items-center text-primary-700 font-semibold hover:text-primary-800 transition">
          <Phone class="mr-2 h-5 w-5" aria-hidden="true" />
          +34 722 66 49 82
        </a>
        <a href="#contacto" class="bg-accent-500 hover:bg-accent-600 text-white px-5 py-2.5 rounded-lg font-semibold transition shadow-md hover:shadow-lg">
          Pedir Cita
        </a>
      </div>
    </div>
  </div>
</header>
