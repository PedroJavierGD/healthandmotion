---
import { Menu, Phone } from "@lucide/astro";
import logo from "../assets/images/logotipo-health-and-motion.webp";
import { mainNavItems } from "../data/navigation";

const ctaHref = "tel:+34722664982";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-4 h-20">
      <div class="flex items-center">
        <a href="/" class="flex items-center" aria-label="Health and Motion">
          <img
            src={logo.src}
            alt="Health and Motion"
            class="h-12 w-auto sm:h-14"
          />
        </a>
      </div>

      <nav class="hidden min-[1180px]:flex items-center space-x-8">
        {mainNavItems.map((item) => (
          <a href={item.href} class="text-gray-600 hover:text-primary-600 font-medium transition">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden min-[1180px]:flex items-center">
        <a href={ctaHref} class="bg-accent-500 hover:bg-accent-600 text-white px-5 py-2.5 rounded-lg font-semibold transition shadow-md hover:shadow-lg">
          Llamar ahora
        </a>
      </div>

      <details class="group relative min-[1180px]:hidden">
        <summary class="flex h-12 w-12 cursor-pointer list-none items-center justify-center rounded-2xl border border-gray-200 bg-white text-gray-700 shadow-sm transition hover:border-primary-200 hover:text-primary-700">
          <span class="sr-only">Abrir menú principal</span>
          <Menu class="h-6 w-6" aria-hidden="true" />
        </summary>

        <div class="absolute right-0 top-[calc(100%+0.75rem)] max-h-[calc(100vh-7rem)] w-[min(22rem,calc(100vw-2rem))] overflow-y-auto rounded-3xl border border-gray-100 bg-white p-5 shadow-2xl">
          <nav class="flex flex-col gap-2">
            {mainNavItems.map((item) => (
              <a
                href={item.href}
                class="rounded-2xl px-4 py-3 font-semibold text-gray-700 transition hover:bg-gray-50 hover:text-primary-700"
              >
                {item.label}
              </a>
            ))}
          </nav>

          <div class="mt-5 border-t border-gray-100 pt-5">
            <a href={ctaHref} class="inline-flex w-full items-center justify-center rounded-xl bg-accent-500 px-5 py-3 font-semibold text-white shadow-md transition hover:bg-accent-600 hover:shadow-lg">
              <Phone class="mr-2 h-5 w-5" aria-hidden="true" />
              Llamar ahora
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
