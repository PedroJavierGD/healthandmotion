---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Servicios from "../components/Servicios.astro";
import PorQueElegirnos from "../components/PorQueElegirnos.astro";
import Equipo from "../components/Equipo.astro";
import Testimonios from "../components/Testimonios.astro";
import Clinica from "../components/Clinica.astro";
import CTA from "../components/CTA.astro";
import DondeEncontrarnos from "../components/DondeEncontrarnos.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Health & Motion | Centro Médico Multidisciplinar">
  <Header />
  <Hero
    title="Tu bienestar integral en"
    highlight="un solo lugar"
    subtitle="Combina entrenamiento personal, estética, fisioterapia, nutrición y psicología. Un equipo de profesionales dedicados a mejorar tu calidad de vida."
  />
  <Servicios />
  <PorQueElegirnos />
  <Equipo />
  <Testimonios />
  <Clinica />
  <CTA />
  <DondeEncontrarnos />
  <Footer />
</Layout>
