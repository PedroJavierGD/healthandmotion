---
import { ChevronRight, NotebookPen, Sparkles } from "@lucide/astro";

import BlogCard from "../components/blog/BlogCard.astro";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getSortedBlogPosts } from "../data/blogPosts";

const posts = getSortedBlogPosts();
---

<Layout
  title="Blog | Health & Motion"
  description="Blog de Health & Motion con artículos sobre fisioterapia, entrenamiento personal, nutrición, psicología, estética y bienestar integral."
>
  <Header />

  <main>
    <section class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(159,179,154,0.24),_transparent_34%),linear-gradient(135deg,_#f5f7f4_0%,_#ffffff_50%,_#fff1f1_100%)] pt-32 pb-20 lg:pt-40 lg:pb-24">
      <div class="absolute -left-20 top-20 h-72 w-72 rounded-full bg-primary-200/40 blur-3xl"></div>
      <div class="absolute right-0 bottom-0 h-80 w-80 rounded-full bg-accent-200/30 blur-3xl"></div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <nav
          aria-label="Breadcrumb"
          class="mb-5 flex flex-wrap items-center justify-center gap-2 text-sm text-gray-500"
        >
          <a href="/" class="transition hover:text-primary-600">Inicio</a>
          <ChevronRight class="h-4 w-4 text-gray-400" aria-hidden="true" />
          <span class="font-medium text-gray-700">Blog</span>
        </nav>

        <div class="inline-flex items-center gap-2 rounded-full border border-primary-200 bg-white/90 px-4 py-2 text-sm font-semibold text-primary-700 shadow-sm">
          <NotebookPen class="h-4 w-4" aria-hidden="true" />
          Blog Health & Motion
        </div>

        <h1 class="mt-6 text-4xl font-extrabold leading-tight text-gray-900 sm:text-5xl lg:text-6xl">
          Artículos prácticos para cuidar mejor tu salud, tu cuerpo y tu bienestar
        </h1>

        <p class="mt-6 text-lg text-gray-600 sm:text-xl">
          Hemos preparado contenidos útiles sobre fisioterapia, entrenamiento,
          nutrición, psicología, estética y salud integral. Los verás ordenados
          del más reciente al más antiguo.
        </p>
      </div>
    </section>

    <section class="bg-white py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-primary-100 px-4 py-2 text-sm font-semibold text-primary-700">
              <Sparkles class="h-4 w-4" aria-hidden="true" />
              Artículos del blog
            </div>
            <h2 class="mt-4 text-3xl font-heading font-bold text-gray-900 sm:text-4xl">
              Publicados de 3 en 3 y ordenados por fecha
            </h2>
            <p class="mt-4 max-w-3xl text-lg text-gray-600">
              Cada artículo incluye una imagen, contenido práctico y acceso
              directo al servicio relacionado para que puedas seguir profundizando.
            </p>
          </div>
        </div>

        <div class="mt-12 grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} showServiceCta={false} />)}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
